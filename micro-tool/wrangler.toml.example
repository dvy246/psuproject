name = "pc"
pages_build_output_dir = "dist"
compatibility_date = "2024-09-23"
compatibility_flags = ["nodejs_compat"]

# ─── D1 Database: PSU Reliability (Template) ──────────────────────────
# Configuration is generated dynamically from the gitignored .env file.
# Copy .env.example to .env and define database_id there.
[[d1_databases]]
binding = "PSU_DB"
database_name = "psu-reliability"
database_id = "PASTE_YOUR_DATABASE_ID_HERE"
