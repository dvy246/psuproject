---
interface Props {
  slot: string; // AdSense slot ID
  client?: string; // AdSense client ID (defaults to a standard config if not passed)
  format?: 'auto' | 'fluid' | 'rectangle' | 'horizontal' | 'vertical';
  responsive?: boolean;
  type?: 'leaderboard' | 'box' | 'sidebar' | 'responsive';
}

const {
  slot,
  client = "ca-pub-XXXXXXXXXXXXXXXX", // Placeholder AdSense Client ID
  format = "auto",
  responsive = true,
  type = "responsive",
} = Astro.props;

// Determine CLS-safe aspect ratio and min-height based on ad type
let minHeight = "90px";
let maxWidth = "100%";
let className = "ad-slot-responsive";

if (type === 'leaderboard') {
  minHeight = "90px";
  maxWidth = "728px";
  className = "ad-slot-leaderboard";
} else if (type === 'box') {
  minHeight = "250px";
  maxWidth = "300px";
  className = "ad-slot-box";
} else if (type === 'sidebar') {
  minHeight = "600px";
  maxWidth = "300px";
  className = "ad-slot-sidebar";
}
---

<div class={`ad-container ${className}`} style={`min-height: ${minHeight}; max-width: ${maxWidth};`}>
  <div class="ad-label">Advertisement</div>
  <div class="ad-content">
    <!-- Google AdSense Ins Tag -->
    <ins class="adsbygoogle"
         style="display:block; text-align:center;"
         data-ad-client={client}
         data-ad-slot={slot}
         data-ad-format={format}
         data-full-width-responsive={responsive ? "true" : "false"}></ins>
    <script is:inline>
      (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </div>
</div>

<style>
  .ad-container {
    margin: 2rem auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--bg-secondary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    overflow: hidden;
    position: relative;
    box-sizing: border-box;
    width: 100%;
    /* Prevent Cumulative Layout Shift (CLS) */
    contain-intrinsic-size: auto 100px;
    content-visibility: auto;
  }

  .ad-label {
    width: 100%;
    font-size: 0.625rem;
    font-weight: 600;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.25rem 0.5rem;
    border-bottom: 1px solid var(--border-subtle);
    background: var(--bg-tertiary);
    text-align: center;
  }

  .ad-content {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: inherit;
    padding: 0.5rem;
  }

  /* Specific sizes */
  .ad-slot-leaderboard {
    min-height: 90px;
  }
  .ad-slot-box {
    min-height: 250px;
  }
  .ad-slot-sidebar {
    min-height: 600px;
  }
  .ad-slot-responsive {
    min-height: 100px;
  }

  /* Hide empty ads cleanly to keep layout polished */
  ins.adsbygoogle[data-ad-status="unfilled"] {
    display: none !important;
  }
</style>
