---
// src/components/ui/MethodologyCard.astro
---
<div class="methodology-card">
  <div class="methodology-badge">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shield-icon">
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      <path d="m9 11 2 2 4-4"/>
    </svg>
    <span>Sizing Methodology Verified</span>
  </div>
  <h3>Transient-Aware Standards</h3>
  <p>
    Sizing calculations are verified against laboratory testing databases (Cybenetics, TechPowerUp) and comply with Intel ATX 3.1 Design Guide specifications.
  </p>
  <a href="/methodology" class="methodology-link">
    Read Sizing Methodology
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="arrow-icon">
      <line x1="5" y1="12" x2="19" y2="12"></line>
      <polyline points="12 5 19 12 12 19"></polyline>
    </svg>
  </a>
</div>

<style>
.methodology-card {
  background: var(--bg-secondary);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-lg);
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.85rem;
  box-shadow: var(--shadow-sm);
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.methodology-card:hover {
  border-color: var(--accent-primary);
  box-shadow: 0 0 15px rgba(0, 229, 255, 0.08);
}

.methodology-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  color: var(--status-safe);
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.shield-icon {
  width: 1rem;
  height: 1rem;
}

.methodology-card h3 {
  font-size: 1rem;
  font-weight: 600;
  color: var(--text-primary);
  margin: 0;
}

.methodology-card p {
  font-size: 0.8125rem;
  color: var(--text-secondary);
  line-height: 1.5;
  margin: 0;
}

.methodology-link {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  color: var(--accent-primary);
  font-size: 0.8125rem;
  font-weight: 500;
  text-decoration: none;
  margin-top: 0.25rem;
  transition: gap 0.2s ease;
}

.methodology-link:hover {
  text-decoration: underline;
}

.methodology-link:hover .arrow-icon {
  transform: translateX(3px);
}

.arrow-icon {
  width: 0.875rem;
  height: 0.875rem;
  transition: transform 0.2s ease;
}
</style>
