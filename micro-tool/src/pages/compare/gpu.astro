---
import Layout from '../../layouts/Layout.astro';
import type { GpuIndex } from '../../types/components';
import gpuData from '../../data/index/gpus.index.json';

// Compute the exact same GPU comparison pairs as in compare/gpu/[slug].astro
const gpus = gpuData.items as GpuIndex[];
const pairs: { a: GpuIndex; b: GpuIndex; slug: string }[] = [];

const tierRank: Record<string, number> = { budget: 0, mid: 1, high: 2, ultra: 3, halo: 4 };

for (let i = 0; i < gpus.length; i++) {
  for (let j = i + 1; j < gpus.length; j++) {
    const a = gpus[i];
    const b = gpus[j];
    const tierDiff = Math.abs(tierRank[a.tier] - tierRank[b.tier]);
    const priceDiff = Math.abs(a.price - b.price);

    // Only pair: same or adjacent tier + within $300 price difference
    if (tierDiff <= 1 && priceDiff <= 300) {
      pairs.push({ a, b, slug: `${a.id}-vs-${b.id}` });
    }
  }
}

// Sort pairs for nice list presentation
pairs.sort((x, y) => `${x.a.name} vs ${x.b.name}`.localeCompare(`${y.a.name} vs ${y.b.name}`));

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "PC GPU Power & Spec Comparisons",
  "url": "https://psucheck.com/compare/gpu",
  "description": "Browse side-by-side power draw and spec comparisons for popular NVIDIA GeForce, AMD Radeon, and Intel Arc graphics cards.",
  "itemListElement": pairs.map((pair, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "url": `https://psucheck.com/compare/gpu/${pair.slug}/`,
    "name": `${pair.a.name} vs ${pair.b.name} Spec Comparison`
  }))
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do I compare two GPUs side-by-side?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Select any two graphics cards from the comparison hub to view their TBP (typical board power), transient spike curves, native connector type, recommended PSU wattage, physical dimensions, VRAM, and clock speeds side-by-side. The comparer highlights which GPU needs a beefier PSU and flags ATX 3.1 compatibility."
      }
    },
    {
      "@type": "Question",
      "name": "What does TBP (Typical Board Power) mean on a GPU?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "TBP (Typical Board Power) is AMD's term — equivalent to NVIDIA's TGP (Total Graphics Power) — representing the sustained average power the entire graphics card draws under a typical gaming or compute load. It is the figure you use when matching a GPU to a PSU wattage, but it does not cover transient spikes which can be significantly higher."
      }
    },
    {
      "@type": "Question",
      "name": "What does GPU tier mean for power draw?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "GPUs are grouped into tiers — budget, mid, high, ultra, and halo — that roughly correlate with their power requirements. A budget GPU may draw under 100W, mid-range cards 100–200W, high-end 200–300W, ultra 300–400W, and halo (flagship) cards can exceed 450W. Tier also indicates what connector type and PSU class you will need."
      }
    },
    {
      "@type": "Question",
      "name": "Why does the GPU connector type matter: 12V-2x6 vs 8-pin PCIe?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The connector type determines whether your PSU is natively compatible. New high-power GPUs (RTX 40-series, RX 7900 XTX and above) use the 12V-2x6 (formerly 12VHPWR) connector, which requires an ATX 3.1 PSU with a native 12V-2x6 port. Older cards use standard 6+2 pin PCIe connectors. The comparison hub flags each GPU's connector and whether it needs an adapter or a native cable."
      }
    },
    {
      "@type": "Question",
      "name": "Why does GPU length matter for case fit?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "GPU length determines whether the card physically fits inside your PC case. High-end cards like the RTX 4090 can exceed 330mm, while compact ITX cases may only accommodate cards under 250mm. Always check your case's maximum GPU clearance and account for front-mounted radiators or fans that reduce usable space."
      }
    },
    {
      "@type": "Question",
      "name": "How much GPU VRAM do I need?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "VRAM requirements depend on resolution and workload: 8GB is adequate for 1080p gaming, 12–16GB is recommended for 1440p, and 16GB+ is ideal for 4K or creative workloads like video editing and 3D rendering. Modern games at high textures can easily consume 10–12GB, so buying more VRAM than you currently need improves future-proofing."
      }
    },
    {
      "@type": "Question",
      "name": "How does GPU power draw affect PSU choice?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A GPU's sustained TBP + transient (instantaneous) spikes determine the minimum PSU wattage you need. For example, a 450W GPU with transient spikes up to 600W needs an 850W+ PSU, not a 650W. The GPU comparison tool calculates both sustained and transient requirements so you know exactly what PSU class is needed to avoid shutdowns under load."
      }
    },
    {
      "@type": "Question",
      "name": "What do GPU clock speeds and boost clock mean?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The base clock is the guaranteed minimum frequency the GPU core runs at under load. Boost clock is the maximum frequency the card can reach under good thermal and power conditions via dynamic frequency scaling. Higher boost clocks generally mean better performance, but real-world speed depends on cooling, power limit, and silicon quality."
      }
    }
  ]
};
---

<Layout
  title="Compare PC Graphics Cards: GPU Power & Spec Comparison Hub — PSUCheck"
  description="Compare power draw, sustained TBP, transient spikes, and connector types of popular NVIDIA GeForce, AMD Radeon, and Intel Arc GPUs side-by-side."
  schema={[schema, faqSchema]}
>
  <section class="calc-hero" aria-labelledby="compare-hero-heading">
    <div class="container">
      <div class="calc-hero-inner">
        <div>
          <div class="calc-breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span aria-hidden="true">›</span>
            <span>Compare</span>
            <span aria-hidden="true">›</span>
            <span aria-current="page">GPUs</span>
          </div>
          <h1 id="compare-hero-heading" class="calc-h1">
            GPU Comparisons
          </h1>
          <p class="calc-subtitle">
            Compare GPU power ratings, transient spikes, connector types, and PSU wattage recommendations side-by-side. Select a matchup below to view the detailed breakdown.
          </p>
        </div>
        <div class="calc-hero-badges" aria-label="Comparer features">
          <span class="badge badge-safe">⚡ TBP & Cable Audit</span>
          <span class="badge badge-safe">⚡ ATX 3.1 & 12V-2x6 Check</span>
          <span class="badge badge-safe">⚖ Spec Headroom</span>
        </div>
      </div>
    </div>
  </section>

  <section class="compare-list-section" style="padding: 4rem 0 6rem; background: var(--bg-primary);">
    <div class="container">
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.25rem;">
        {pairs.map((pair) => (
          <a
            href={`/compare/gpu/${pair.slug}/`}
            class="card card-accent"
            style="padding: 1.5rem; text-decoration: none; display: flex; flex-direction: column; justify-content: space-between; transition: transform 150ms ease, border-color 150ms ease; border: 1px solid var(--border-subtle);"
            onmouseenter="this.style.transform='translateY(-2px)'; this.style.borderColor='var(--color-accent-violet)';"
            onmouseleave="this.style.transform='none'; this.style.borderColor='var(--border-subtle)';"
          >
            <div>
              <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem;">
                <span class="badge" style="background: var(--bg-tertiary); color: var(--text-secondary); font-size: 0.75rem; border: 1px solid var(--border-default); text-transform: capitalize;">
                  {pair.a.tier} Tier
                </span>
                <span style="font-size: 0.8125rem; color: var(--text-tertiary);">
                  Price Diff: ${Math.abs(pair.a.price - pair.b.price)}
                </span>
              </div>
              <h2 style="font-size: 1.125rem; font-weight: 700; color: var(--text-primary); margin: 0 0 0.5rem 0; line-height: 1.4;">
                {pair.a.name} <span style="color: var(--text-tertiary); font-weight: 400; font-size: 0.9rem;">vs</span> {pair.b.name}
              </h2>
              <p style="font-size: 0.8125rem; color: var(--text-secondary); line-height: 1.5; margin: 0;">
                Compare {pair.a.tbp}W TBP vs {pair.b.tbp}W TBP power draws, native {pair.a.connectorType === '12v-2x6' ? '12V-2x6 / 12VHPWR' : 'PCIe'} connector safety, and transient spike curves.
              </p>
            </div>
            <div style="margin-top: 1.25rem; display: flex; align-items: center; gap: 0.375rem; font-size: 0.8125rem; font-weight: 700; color: var(--color-accent-violet);">
              View Comparison
              <span aria-hidden="true">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
