---
import Layout from '../../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "PC Hardware Comparison & Electrical Safety Tools — PSUCheck",
  "url": "https://psucheck.com/compare/",
  "description": "Access side-by-side spec comparers and electrical load calculators for sizing power supplies, backing up battery UPS runtimes, and planning room circuit breaker loads."
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "name": "PSUCheck Comparison Tools — Frequently Asked Questions",
  "url": "https://psucheck.com/compare/",
  "description": "Common questions about using PSUCheck's component comparison tools and electrical safety calculators.",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What comparison tools are available?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "PSUCheck offers PSU Spec Comparison (compare two power supplies side-by-side), CPU Power Comparison, GPU Power Comparison, UPS Battery Sizer, Circuit Breaker Planner, Desktop vs Laptop TCO calculator, and Cable Compatibility tools — all focused on power draw, transient spikes, and electrical safety."
      }
    },
    {
      "@type": "Question",
      "name": "How do I compare two PSUs?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Navigate to the PSU Spec Comparison tool, select your two power supply models from the dropdown lists, and the tool will display a side-by-side comparison of modularity, 80 PLUS vs Cybenetics efficiency ratings, native 12V-2x6 connector support, fan size, and cost-per-watt value."
      }
    },
    {
      "@type": "Question",
      "name": "How do I compare two GPUs for power draw?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Open the GPU Power Comparison tool and choose up to two graphics cards. The tool compares total board power (TBP), sub-millisecond transient spikes, recommended PSU wattage, PCIe slot draw, and 12V-2x6 connector requirements for NVIDIA GeForce, AMD Radeon, and Intel Arc models."
      }
    },
    {
      "@type": "Question",
      "name": "What is a GPU upgrade checker?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The GPU upgrade checker evaluates whether your existing power supply can handle a new graphics card. Input your current PSU wattage and the target GPU; the tool analyzes sustained load, transient headroom, and connector compatibility before recommending an upgrade path or a PSU swap."
      }
    },
    {
      "@type": "Question",
      "name": "What is a UPS sizer and when do I need it?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The UPS Battery Sizer calculates the minimum VA rating your uninterruptible power supply needs to safely support a gaming PC during a blackout. Use it when planning a home office, building a new rig, or if you have experienced sudden shutdowns during power flickers."
      }
    },
    {
      "@type": "Question",
      "name": "What is a circuit breaker planner?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Circuit Breaker Planner audits all devices sharing a bedroom or office electrical circuit. It accounts for the combined draw of a gaming PC, monitor, air conditioner, space heater, and other peripherals to determine whether a 15 A or 20 A breaker will trip under load."
      }
    },
    {
      "@type": "Question",
      "name": "How does the cable compatibility tool work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The cable compatibility tool helps you verify whether your existing PSU cables (CPU, PCIe, SATA, 12V-2x6) match a new power supply or component. Select your current PSU model and target hardware; the tool flags mismatched pinouts and warns against mixing incompatible cables across different PSU brands or series."
      }
    },
    {
      "@type": "Question",
      "name": "What is the desktop vs laptop TCO calculator?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Desktop vs Laptop TCO (Total Cost of Ownership) calculator compares continuous power draw differences and projects 5-year electricity bills for a custom desktop rig versus a gaming or creator laptop. It factors in regional kWh rates, typical usage hours per day, and idle vs load power consumption."
      }
    }
  ]
};

const comparisonTools = [
  {
    title: "⚡ PSU Spec Comparison",
    description: "Compare two power supplies side-by-side. Analyze modularity, efficiency standards (80 PLUS vs Cybenetics), native 12V-2x6 connectors, and cost-per-watt values.",
    href: "/compare/psu/",
    badge: "Interactive Tool",
    badgeType: "accent"
  },
  {
    title: "⚙ CPU Power Comparison",
    description: "Compare AMD Ryzen and Intel Core sustained TDP, peak turbo PL2 limits, socket compatibility, and recommended safety margins.",
    href: "/compare/cpu/",
    badge: "110+ Matchups",
    badgeType: "safe"
  },
  {
    title: "🎮 GPU Power Comparison",
    description: "Compare NVIDIA GeForce, AMD Radeon, and Intel Arc total board powers, sub-millisecond transient spikes, and PCIe vs 12V-2x6 connector formats.",
    href: "/compare/gpu/",
    badge: "150+ Matchups",
    badgeType: "safe"
  },
  {
    title: "🔋 UPS Battery Sizer",
    description: "Calculate what VA rating UPS your gaming PC requires. Estimate reserve battery runtimes under game load and verify Active PFC wave support.",
    href: "/compare/ups-calculator/",
    badge: "Safety Sizer",
    badgeType: "warning"
  },
  {
    title: "🔌 Circuit Breaker Planner",
    description: "Audit bedroom electrical circuit loads. Check if running a high-end gaming PC alongside ACs, space heaters, or monitors will trip 15A/20A breakers.",
    href: "/compare/breaker-calculator/",
    badge: "Safety Auditor",
    badgeType: "warning"
  },
  {
    title: "📉 Desktop vs Laptop TCO",
    description: "Compare continuous power draw differences and 5-year electricity bills between custom desktop rigs and gaming/creator laptops.",
    href: "/compare/desktop-vs-laptop/",
    badge: "TCO Estimator",
    badgeType: "accent"
  }
];
---

<Layout
  title="PC Component Comparisons & Electrical Safety Calculators — PSUCheck"
  description="Compare CPU and GPU transient power specs, side-by-side PSU standards, UPS backup battery runtimes, and bedroom circuit breaker limits."
  schema={[schema, faqSchema]}
>
  <section class="calc-hero" aria-labelledby="compare-hub-heading">
    <div class="container">
      <div class="calc-hero-inner">
        <div>
          <div class="calc-breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span aria-hidden="true">›</span>
            <span aria-current="page">Compare</span>
          </div>
          <h1 id="compare-hub-heading" class="calc-h1">
            PC Component Comparisons &amp; Electrical Tools
          </h1>
          <p class="calc-subtitle">
            Unbiased specifications, transient spike data, and electrical safety planning resources. Sourced from CLEAResult 80 PLUS, Cybenetics Lab, and official manufacturer specifications.
          </p>
        </div>
        <div class="calc-hero-badges" aria-label="Hub features">
          <span class="badge badge-safe">⚡ Spec Comparers</span>
          <span class="badge badge-safe">🔌 Electrical Safety Suite</span>
          <span class="badge badge-safe">📊 5-Year TCO Auditing</span>
        </div>
      </div>
    </div>
  </section>

  <section class="compare-hub-section" style="padding: 4rem 0 6rem; background: var(--bg-primary);">
    <div class="container">
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 1.5rem;">
        {comparisonTools.map((tool) => (
          <a
            href={tool.href}
            class="card card-accent"
            style="padding: 2rem; text-decoration: none; display: flex; flex-direction: column; justify-content: space-between; transition: transform 150ms ease, border-color 150ms ease; border: 1px solid var(--border-subtle);"
            onmouseenter="this.style.transform='translateY(-2px)'; this.style.borderColor='var(--color-accent-violet)';"
            onmouseleave="this.style.transform='none'; this.style.borderColor='var(--border-subtle)';"
          >
            <div>
              <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                <h2 style="font-size: 1.25rem; font-weight: 800; color: var(--text-primary); margin: 0; line-height: 1.3;">
                  {tool.title}
                </h2>
                <span class={`badge badge-${tool.badgeType}`} style="font-size: 0.75rem;">
                  {tool.badge}
                </span>
              </div>
              <p style="font-size: 0.875rem; color: var(--text-secondary); line-height: 1.6; margin: 0;">
                {tool.description}
              </p>
            </div>
            <div style="margin-top: 1.5rem; display: flex; align-items: center; gap: 0.375rem; font-size: 0.875rem; font-weight: 700; color: var(--color-accent-violet);">
              Launch Tool
              <span aria-hidden="true">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
