---
import Layout from '../../layouts/Layout.astro';
import { PsuComparer } from '../../components/calculators/PsuComparer';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How do I compare two power supplies?", "acceptedAnswer": { "@type": "Answer", "text": "Focus on wattage rating, efficiency certification (80+ Bronze through Titanium), modularity type, ATX version, protection features, and physical dimensions. Select two PSUs above to see a side-by-side comparison across all these metrics." } },
    { "@type": "Question", "name": "What does the ATX version tell me?", "acceptedAnswer": { "@type": "Answer", "text": "ATX 3.0 and 3.1 PSUs include native 12VHPWR or 12V-2x6 connectors required for RTX 40 and 50 series GPUs. They also guarantee handling of 200% transient power excursions. Older ATX 2.x PSUs work with adapters but lack native transient tolerance." } },
    { "@type": "Question", "name": "Is modular or non-modular PSU better?", "acceptedAnswer": { "@type": "Answer", "text": "Fully modular PSUs let you detach all cables, making cable management cleaner. Semi-modular units have fixed essential cables with detachable peripheral cables. Non-modular units have all cables fixed and cost less but are harder to manage." } },
    { "@type": "Question", "name": "What efficiency rating should I look for?", "acceptedAnswer": { "@type": "Answer", "text": "80+ Gold is the best value for most builds (87-90% efficiency). Platinum adds 2-3% efficiency for 30-50% higher cost. Titanium is for 24/7 operation. Bronze is adequate for budget builds; the electricity cost difference vs Gold is roughly $8-15 per year." } },
    { "@type": "Question", "name": "Do I need a Cybenetics rated PSU?", "acceptedAnswer": { "@type": "Answer", "text": "Cybenetics provides independent efficiency and noise testing at more load points than 80 PLUS. ETA-A++ roughly equals Titanium. Cybenetics noise ratings (A+ through Standard) help you choose quieter units, especially important for silent builds." } },
    { "@type": "Question", "name": "What protection features matter most?", "acceptedAnswer": { "@type": "Answer", "text": "OCP (Over Current Protection) prevents damage from transient spikes. OVP protects against voltage surges. SCP prevents short circuit damage. OTP prevents overheating. A quality PSU should have all four." } },
    { "@type": "Question", "name": "Does PSU wattage affect electricity bills?", "acceptedAnswer": { "@type": "Answer", "text": "No. A PSU only draws what your components demand. A 1200W PSU powering a 500W system draws approximately 500W plus conversion loss. A larger PSU may run more efficiently if it stays in the 40-60% load sweet spot." } },
    { "@type": "Question", "name": "How does PSU physical size affect compatibility?", "acceptedAnswer": { "@type": "Answer", "text": "PSU dimensions determine case compatibility. Standard ATX PSUs are 150mm wide and 86mm tall but vary in length from 130mm to 200mm+. Check your case maximum PSU length before purchasing. The compare view shows dimensions for direct comparison." } }
  ]
};

const schema = {
  "@type": "WebApplication",
  "name": "PSUCheck PSU Comparer",
  "url": "https://psucheck.com/compare/psu",
  "applicationCategory": "UtilitiesApplication",
  "description": "Compare two PC power supplies side-by-side. Analyze modularity, efficiency, ATX 3.1 compliance, 12V-2x6 cable support, and price differences.",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
};
---

<Layout
  title="Compare PC Power Supplies: Side-by-Side PSU Spec Comparison — PSUCheck"
  description="Select and compare two power supplies side-by-side. Analyze ATX standard differences (2.x vs 3.1), modularity configurations, native cables, and estimated pricing."
  schema={[schema, faqSchema]}
>
  <section class="calc-hero" aria-labelledby="compare-hero-heading">
    <div class="container">
      <div class="calc-hero-inner">
        <div>
          <div class="calc-breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span aria-hidden="true">›</span>
            <span>Compare</span>
            <span aria-hidden="true">›</span>
            <span aria-current="page">PSUs</span>
          </div>
          <h1 id="compare-hero-heading" class="calc-h1">
            Compare Power Supplies
          </h1>
          <p class="calc-subtitle">
            Select two power supplies from our database to compare specifications, standards,
            efficiency ratings, noise levels, and estimated retail prices side-by-side.
          </p>
        </div>
        <div class="calc-hero-badges" aria-label="Comparer features">
          <span class="badge badge-safe">⚖ Side-by-Side Specs</span>
          <span class="badge badge-safe">⚡ ATX 3.1 Check</span>
          <span class="badge badge-safe">🔌 12V-2x6 Audit</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Comparer Section -->
  <section class="compare-section">
    <div class="container">
      <!-- Preact Island -->
      <PsuComparer client:load />
    </div>
  </section>
</Layout>

<style is:global>
.compare-section {
  padding: 4rem 0 6rem;
  background: var(--bg-primary);
}
.compare-selectors-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
  align-items: center;
}
@media (min-width: 768px) {
  .compare-selectors-grid {
    grid-template-columns: 1fr auto 1fr;
  }
}
.compare-selector-box {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.compare-label {
  font-size: 0.8125rem;
  font-weight: 600;
  color: var(--text-secondary);
}
.compare-dropdown {
  background: var(--bg-secondary);
  border: 1px solid var(--border-default);
  color: var(--text-primary);
  font-size: 0.9375rem;
  padding: 0.625rem 0.875rem;
  border-radius: var(--radius-md);
  min-height: 44px;
}
.compare-vs-badge {
  text-align: center;
  font-weight: 900;
  font-size: 1.25rem;
  color: var(--text-tertiary);
  padding-top: 1rem;
}
.compare-header-name {
  font-size: 1rem;
  font-weight: 800;
  color: var(--text-primary);
}
.compare-value {
  text-align: center;
  font-size: 0.9375rem;
  color: var(--text-secondary);
}
.compare-price {
  font-weight: 800;
  color: var(--accent-primary);
}
.compare-highlight-green {
  color: var(--status-safe) !important;
  font-weight: 600;
}
.compare-highlight-red {
  color: var(--status-danger) !important;
}
.text-capitalize {
  text-transform: capitalize;
}
</style>
