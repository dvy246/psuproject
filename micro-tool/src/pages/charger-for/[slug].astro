---
import Layout from '../../layouts/Layout.astro';
import { getChargerVerdicts, getRecommendedChargers } from '../../lib/charger-matcher';
import type { LaptopIndex } from '../../lib/charger-matcher';
import laptopData from '../../data/index/laptops.index.json';

export async function getStaticPaths() {
  const laptops = laptopData.items as LaptopIndex[];
  return laptops.map(laptop => ({
    params: { slug: laptop.id },
    props: { laptop }
  }));
}

const { laptop } = Astro.props as { laptop: LaptopIndex };

// Compatibility verdicts
const verdicts = getChargerVerdicts(laptop);

// GaN recommendations
const recommendations = getRecommendedChargers(laptop);

const pageTitle = `Best USB-C Charger for ${laptop.name} — Sizing Guide | PSUCheck`;
const pageDescription = `Find the best USB-C GaN charger compatibility settings for ${laptop.name}. Analyze charging times, compatibility verdicts for 30W-140W adapters, and recommended GaN models.`;

// Schema Markup
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `Can I charge my ${laptop.name} with a 65W charger?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": laptop.maxChargeWatts <= 65
          ? `Yes! A 65W charger is fully compatible with the ${laptop.name} and will charge it at its maximum supported rate of ${laptop.maxChargeWatts}W.`
          : `Yes, but it will charge slower than maximum speed. The ${laptop.name} supports up to ${laptop.maxChargeWatts}W fast charging. A 65W charger is sufficient for standard workloads but may charge slowly under heavy CPU/GPU loads.`
      }
    },
    {
      "@type": "Question",
      "name": `Does the ${laptop.name} support USB-C Power Delivery fast charging?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Yes, the ${laptop.name} supports USB-C Power Delivery (PD) charging protocol up to ${laptop.maxChargeWatts}W using the ${laptop.protocol} standard.`
      }
    }
  ]
};

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": `${laptop.name} USB-C Charging Guide`,
  "description": `Charging specifications, charger compatibility matrices, and GaN power adapter picks for the ${laptop.name}.`,
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://psucheck.com/" },
    { "@type": "ListItem", "position": 2, "name": "PSU Finder", "item": "https://psucheck.com/charger-for/" },
    { "@type": "ListItem", "position": 3, "name": laptop.name }
  ]
};

const schemas = [breadcrumbSchema, faqSchema, productSchema];

const verdictLabels: Record<string, string> = {
  fast: '⚡ Fast Charging',
  standard: '✓ Standard Sizing',
  slow: '⚠ Slow Sizing',
  incompatible: '✕ Incompatible'
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  schema={schemas}
>
  <section class="sizing-page" aria-labelledby="sizing-heading">
    <div class="container">
      <nav class="calc-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/charger-for">PSU Finder</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">{laptop.name}</span>
      </nav>

      <header class="sizing-header">
        <div class="section-eyebrow">USB-C PD Sizing Guide</div>
        <h1 id="sizing-heading">
          Best Charger for the <span class="gradient-text">{laptop.name}</span>
        </h1>
        <p class="sizing-intro">
          Full technical compatibility matrix detailing power limits, charging times, and third-party GaN options.
        </p>
      </header>

      {/* === METRICS GRID === */}
      <div class="sizing-grid">
        <div class="card card-dark">
          <h2>Laptop Charging Profile</h2>
          <div class="stat-stack">
            <div class="stat-row">
              <span class="stat-label">Model Name</span>
              <span class="stat-val">{laptop.name}</span>
            </div>
            <div class="stat-row">
              <span class="stat-label">Battery Capacity</span>
              <span class="stat-val tabular">{laptop.batteryCapacityWh} Wh</span>
            </div>
            <div class="stat-row">
              <span class="stat-label">Maximum USB-C Input</span>
              <span class="stat-val tabular" style="color:var(--color-accent-cyan); font-weight:800;">{laptop.maxChargeWatts}W</span>
            </div>
            <div class="stat-row">
              <span class="stat-label">Protocol Standards</span>
              <span class="stat-val">{laptop.protocol}</span>
            </div>
            <div class="stat-row">
              <span class="stat-label">Typical Idle/Office Draw</span>
              <span class="stat-val tabular">{laptop.typicalOfficeWatts}W</span>
            </div>
            <div class="stat-row">
              <span class="stat-label">Typical Peak Load Draw</span>
              <span class="stat-val tabular">{laptop.typicalLoadWatts}W</span>
            </div>
            <div class="stat-row">
              <span class="stat-label">Connector Output Port</span>
              <span class="stat-val">{laptop.connectorType}</span>
            </div>
          </div>
        </div>

        <div class="card card-dark">
          <h2>Power Compatibility Verdicts</h2>
          <p style="font-size:0.8125rem; color:var(--text-secondary); margin-bottom:1rem;">
            Estimated battery behavior at standard USB-C charger wattages:
          </p>
          <div class="verdict-list" style="display:flex; flex-direction:column; gap:0.75rem;">
            {verdicts.map(v => (
              <div class="verdict-item" key={v.wattage} style="display:flex; align-items:center; justify-content:space-between; padding-bottom:0.5rem; border-bottom:1px solid var(--color-border-subtle);">
                <div style="display:flex; flex-direction:column; gap:0.15rem;">
                  <span style="font-weight:700; color:var(--text-primary);">{v.wattage}W USB-C Charger</span>
                  <span style="font-size:0.75rem; color:var(--text-secondary); max-width:28ch;">{v.description}</span>
                </div>
                <div style="text-align:right; display:flex; flex-direction:column; gap:0.25rem;">
                  <span class={`badge badge-${v.statusClass}`} style="font-size:0.75rem;">
                    {verdictLabels[v.verdict]}
                  </span>
                  {v.chargeTimeMins > 0 && (
                    <span style="font-size:0.6875rem; color:var(--text-tertiary);">Est. 0-80%: <strong>{v.chargeTimeMins}m</strong></span>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      {/* === GAN PRODUCT RECOMMENDATIONS === */}
      {recommendations.length > 0 && (
        <section class="gan-section" aria-labelledby="gan-heading" style="margin-top: 3rem;">
          <h2 id="gan-heading">Recommended Third-Party GaN Chargers</h2>
          <p style="font-size:0.875rem; color:var(--text-secondary); margin-bottom:1.5rem;">
            These highly compact Gallium Nitride (GaN) chargers are tested compatible with the {laptop.name}'s charging protocols:
          </p>
          <div class="gan-grid" style="display:grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap:1rem;">
            {recommendations.map(charger => (
              <div class="gan-card card" key={charger.id} style="display:flex; flex-direction:column; justify-content:space-between; padding:1.25rem; border:1px solid var(--color-border-subtle); border-radius:var(--radius-lg);">
                <div>
                  <div style="font-size:0.6875rem; font-weight:700; color:var(--text-tertiary); text-transform:uppercase;">{charger.brand}</div>
                  <h3 style="font-size:1.05rem; font-weight:700; margin:0.25rem 0; color:var(--text-primary);">{charger.name}</h3>
                  <div style="font-size:0.75rem; color:var(--text-secondary); margin-bottom:0.75rem;">{charger.ports} · {charger.wattage}W Max</div>
                  <p style="font-size:0.8125rem; color:var(--text-secondary); line-height:1.4; margin:0;">{charger.highlight}</p>
                </div>
                <div style="display:flex; justify-content:space-between; align-items:center; margin-top:1.5rem; border-top:1px solid var(--color-border-subtle); padding-top:0.75rem;">
                  <span style="font-weight:800; font-family:var(--font-mono); color:var(--color-accent-cyan); font-size:1.15rem;">${charger.price}</span>
                  <a href={charger.affiliateUrl} target="_blank" rel="noopener noreferrer" class="btn btn-secondary btn-sm">Buy on Amazon →</a>
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      {/* === INTERNAL QUICK LINKS === */}
      <section class="links-section" aria-labelledby="links-heading" style="margin-top: 3rem;">
        <h2 id="links-heading">Browse Other Charger Sizing Guides</h2>
        <div class="links-grid" style="display:grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap:0.75rem;">
          <a href="/charger-for" class="link-card card" style="display:flex; justify-content:space-between; align-items:center; padding:1rem 1.25rem; text-decoration:none; border:1px solid var(--color-border-subtle); border-radius:var(--radius-lg); transition:border-color 0.15s;">
            <span style="font-size:0.875rem; font-weight:600; color:var(--text-primary);">View All Laptop Charger Sizers</span>
            <span style="color:var(--color-accent-cyan); font-weight:700;">→</span>
          </a>
          <a href="/compare/desktop-vs-laptop" class="link-card card" style="display:flex; justify-content:space-between; align-items:center; padding:1rem 1.25rem; text-decoration:none; border:1px solid var(--color-border-subtle); border-radius:var(--radius-lg); transition:border-color 0.15s;">
            <span style="font-size:0.875rem; font-weight:600; color:var(--text-primary);">Desktop vs. Laptop Electricity Cost</span>
            <span style="color:var(--color-accent-cyan); font-weight:700;">→</span>
          </a>
        </div>
      </section>
    </div>
  </section>
</Layout>

<style>
.sizing-page {
  padding: 3rem 0 6rem;
}
.sizing-header {
  margin-top: 1.5rem;
  margin-bottom: 2.5rem;
}
.sizing-header h1 {
  font-size: clamp(1.75rem, 4.5vw, 2.75rem);
  font-weight: 850;
  line-height: 1.15;
  letter-spacing: -0.03em;
}
.sizing-intro {
  font-size: 1rem;
  color: var(--text-secondary);
  margin-top: 0.75rem;
}

/* Grid */
.sizing-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
}
@media (min-width: 768px) {
  .sizing-grid {
    grid-template-columns: 1fr 1fr;
  }
}
.card-dark {
  background: var(--color-surface);
  border: 1px solid var(--color-border-subtle);
  padding: 1.5rem;
  border-radius: var(--radius-lg);
}
.card-dark h2 {
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--text-primary);
}
.stat-stack {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  margin-top: 1.5rem;
}
.stat-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 0.875rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--color-border-subtle);
}
.stat-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}
.stat-label {
  color: var(--text-secondary);
}
.stat-val {
  font-weight: 700;
  color: var(--text-primary);
}

.btn-sm {
  font-size: 0.75rem !important;
  padding: 6px 12px !important;
  min-height: 32px !important;
}
.link-card:hover {
  border-color: var(--color-accent-cyan);
}
</style>
