    {
      "@type": "Question",
      "name": "Why do PC power supplies degrade over time?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Power supplies degrade because the liquid electrolyte inside their aluminum capacitors slowly evaporates over years of thermal cycles, reducing capacitance and increasing resistance."
      }
    },
    {
      "@type": "Question",
      "name": "How do you calculate PSU capacity loss?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For premium units, deduct 5% of the original wattage rating annually for every year past year 3. For budget units, deduct 8% to 10% annually starting from the first year."
      }
    },
    {
      "@type": "Question",
      "name": "How does operating temperature affect PSU lifespan?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "According to chemical laws, every 10°C increase in operating temperature doubles the rate of electrolyte evaporation, cutting the capacitor's lifespan in half."
      }
    },
    {
      "@type": "Question",
      "name": "What are the symptoms of a degraded power supply?",
      "acceptedAnswer": {
