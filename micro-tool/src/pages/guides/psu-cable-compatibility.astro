<Layout
  title="PSU Modular Cable Compatibility: Pinout Safety Guide — PSUCheck"
  description="Learn about the dangers of mixing modular PSU cables. Understand proprietary pinouts, voltage cross-overs, and how to verify cable compatibility safely."
  schema={faqSchema}
>
  <article class="guide-article">
    <div class="container">
