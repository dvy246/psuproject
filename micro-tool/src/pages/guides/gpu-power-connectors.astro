---
import Layout from '../../layouts/Layout.astro';
import TableOfContents from '../../components/ui/TableOfContents';
import MethodologyCard from '../../components/ui/MethodologyCard.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "datePublished": "2026-07-13",
  "dateModified": "2026-07-13",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the 12V-2x6 connector?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The 12V-2x6 connector is the PCIe CEM 5.1 physical specification replacing the older 12VHPWR design. It shortens the sense pins so that if the cable is not fully plugged in, the PSU limits power to prevent port melting."
      }
    }
  ]
};
---

<Layout
  title="GPU Power Connectors: 8-pin, 12VHPWR, & 12V-2x6 Guide — PSUCheck"
  description="A guide to modern GPU power connectors. Understand 8-pin PCIe cables, 12VHPWR pins, and the new ATX 3.1 12V-2x6 safety connectors."
  schema={faqSchema}
>
  <article class="guide-article">
    <div class="container">
      <header class="guide-header">
        <div class="guide-meta">
          <a href="/methodology" class="badge badge-safe" style="text-decoration:none;">✓ Sizing Methodology Verified</a>
          <span>Updated: July 13, 2026</span>
        </div>
        <h1>GPU Power Connectors: 8-pin, 12VHPWR, &amp; 12V-2x6</h1>
        <p class="guide-lead">
          Modern graphics cards draw massive power, requiring specialized power connectors.
          This guide outlines old standard PCIe cables and the revised ATX 3.1 connectors.
        </p>
      </header>

      <div class="guide-layout">
        <main class="guide-content" id="main-content">
          <h2>Classic 8-Pin PCIe Connectors</h2>
          <p>
            Standard 8-pin PCIe power cables are rated to supply up to 150W of power safely.
            High-draw GPUs historically required up to three or four of these cables.
          </p>
          <div class="important-warning">
            <strong>⚠ Daisy-Chaining Warning:</strong> Never use a single cable with two daisy-chained 8-pin heads
            for cards drawing more than 225W. Always run separate, individual PCIe cables directly from the PSU.
          </div>

          <h2>The 12VHPWR Connector (ATX 3.0)</h2>
          <p>
            Introduced with PCIe 5.0 and ATX 3.0, the 12VHPWR connector delivers up to 600W through a single cable.
            However, minor installation errors (loose connections) caused ports to melt on heavy loads.
          </p>

          <h2>The 12V-2x6 Connector (ATX 3.1)</h2>
          <p>
            ATX 3.1 adopts the 12V-2x6 connector. It fixes the melting issue by shortening the sense/signal pins.
            If the plug shifts out of its slot, the sense pins lose contact first, signaling the PSU to drop output to 150W,
            avoiding fire hazards entirely.
          </p>

          <div style="margin-top:3rem;">
            <a href="/psu-calculator" class="btn btn-primary">Check GPU cable requirements</a>
          </div>
        </main>

        <aside class="guide-sidebar">
          <TableOfContents client:load />
          <MethodologyCard />
          <div class="card">
            <h3>Calculators</h3>
            <ul style="list-style:none;padding:0;display:flex;flex-direction:column;gap:0.5rem;font-size:0.875rem;">
              <li><a href="/psu-calculator">⚡ PSU Calculator</a></li>
              <li><a href="/pc-builder">🖥️ PC Build Cost Calculator</a></li>
            </ul>
          </div>
          <div class="card">
            <h3>Other Guides</h3>
            <ul style="list-style:none;padding:0;display:flex;flex-direction:column;gap:0.5rem;font-size:0.875rem;">
              <li><a href="/guides/atx-3-1-guide">ATX 3.1 Guide</a></li>
              <li><a href="/guides/psu-cable-extensions">Cable Extensions Safety</a></li>
              <li><a href="/guides/psu-sizing-guide">PSU Sizing Guide</a></li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </article>
</Layout>

<style>
.guide-article { padding: 4rem 0; }
.guide-header { margin-bottom: 3rem; }
.guide-meta { display:flex; gap: 1rem; align-items:center; font-size: 0.8125rem; color: var(--text-tertiary); margin-bottom: 0.75rem; }
.guide-lead { font-size: 1.15rem; color: var(--text-secondary); max-width: 65ch; line-height: 1.65; margin-top: 0.5rem; }
.guide-layout { display: grid; grid-template-columns: 1fr; gap: 3rem; }
@media (min-width: 1024px) {
  .guide-layout { grid-template-columns: minmax(0, 8fr) minmax(0, 4fr); }
}
.guide-content h2 { margin-top: 2.5rem; margin-bottom: 1rem; }
.guide-content p, .guide-content li { color: var(--text-secondary); line-height: 1.75; margin-bottom: 1rem; }
.guide-content ul { padding-left: 1.5rem; margin-bottom: 1.5rem; }
.important-warning { background: var(--color-surface-raised); border-left: 4px solid var(--color-accent-orange); padding: 1rem; border-radius: var(--radius-md); margin-top: 1rem; color: var(--text-secondary); }
.guide-sidebar { display:flex; flex-direction:column; gap: 1.5rem; }
.guide-sidebar .card { padding: 1.25rem; }
</style>
