---
import Layout from '../../layouts/Layout.astro';
import TableOfContents from '../../components/ui/TableOfContents';
import MethodologyCard from '../../components/ui/MethodologyCard.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "datePublished": "2026-07-13",
  "dateModified": "2026-07-14",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the difference between SFX and ATX power supplies?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The primary difference is size. ATX is the standard desktop form factor (150mm x 86mm x 140mm+), whereas SFX is designed for small form factor cases (125mm x 63.5mm x 100mm). SFX units use smaller fans (usually 80-92mm) and shorter cables."
      }
    },
    {
      "@type": "Question",
      "name": "Can I install an SFX PSU in an ATX case?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, but you will need an SFX-to-ATX adapter bracket. Many premium SFX power supplies include this bracket in the box. You may also need cable extensions since SFX power cables are significantly shorter than standard ATX cables."
      }
    }
  ]
};
---

<Layout
  title="SFX vs ATX PSU: Form Factors & Mounting Guide — PSUCheck"
  description="Learn the differences between SFX and ATX power supplies. Explore dimensions, brackets, cable lengths, and cooling configurations for SFF builds."
  schema={faqSchema}
>
  <article class="guide-article">
    <div class="container">
      <nav class="calc-breadcrumb" aria-label="Breadcrumb" style="margin-bottom: 1.5rem;">
        <a href="/">Home</a>
        <span aria-hidden="true" style="margin: 0 0.5rem; opacity: 0.5;">›</span>
        <a href="/guides/">Guides</a>
        <span aria-hidden="true" style="margin: 0 0.5rem; opacity: 0.5;">›</span>
        <span aria-current="page">SFX vs ATX PSU</span>
      </nav>

      <header class="guide-header">
        <div class="guide-meta">
          <a href="/methodology" class="badge badge-safe" style="text-decoration:none;">✓ Sizing Methodology Verified</a>
          <span>Updated: July 14, 2026</span>
          <span style="margin: 0 0.5rem; opacity: 0.5;">•</span>
          <span class="reading-time-badge">2 min read</span>
        </div>
        <h1>SFX vs ATX PSU: Small Form Factor vs Desktop Standard</h1>
        <p class="guide-lead">
          Choosing between an SFX and ATX power supply depends entirely on your PC chassis volume.
          This guide outlines the differences in sizing, noise levels, and installation constraints.
        </p>
      </header>

      <div class="guide-layout">
        <main class="guide-content" id="main-content">
          <div class="adsense-placeholder" style="margin: 1.5rem 0; padding: 1rem; border: 1px dashed var(--border-subtle); text-align: center; color: var(--text-tertiary); font-size: 0.75rem; border-radius: 4px;">
            ADVERTISEMENT — LEADERBOARD
          </div>

          <h2 id="dimensions">Form Factor Dimensions</h2>
          <p>
            The physical volume comparison between these two standards is substantial:
          </p>
          <ul>
            <li><strong>ATX (Advanced Technology eXtended):</strong> 150 mm width × 86 mm height × 140 mm (to 200 mm) depth.</li>
            <li><strong>SFX (Small Form Factor):</strong> 125 mm width × 63.5 height × 100 mm depth.</li>
            <li><strong>SFX-L (Slightly longer SFX):</strong> 125 mm width × 63.5 height × 125 mm depth (accommodates a larger 120mm fan).</li>
          </ul>
          <p>
            SFX power supplies are roughly half the volume of a standard ATX unit, freeing up critical space for airflow and routing in Mini-ITX cases (such as the Lian Li A4-H2O or Fractal Ridge).
          </p>

          <div class="adsense-placeholder" style="margin: 1.5rem 0; padding: 1rem; border: 1px dashed var(--border-subtle); text-align: center; color: var(--text-tertiary); font-size: 0.75rem; border-radius: 4px;">
            ADVERTISEMENT — IN-CONTENT BANNER
          </div>

          <h2 id="clearances-table">Form Factor Clearance Comparison</h2>
          <div style="overflow-x: auto; margin-bottom: 2rem;">
            <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.875rem;">
              <thead>
                <tr style="border-bottom: 2px solid var(--border-subtle); color: var(--text-secondary);">
                  <th style="padding: 0.5rem 0.75rem;">PSU Form Factor</th>
                  <th style="padding: 0.5rem 0.75rem;">Width × Height × Depth</th>
                  <th style="padding: 0.5rem 0.75rem;">Max Fan Size</th>
                  <th style="padding: 0.5rem 0.75rem;">Standard Cable Length</th>
                </tr>
              </thead>
              <tbody>
                <tr style="border-bottom: 1px solid var(--border-subtle);">
                  <td style="padding: 0.75rem; font-weight: 700;">Standard ATX</td>
                  <td style="padding: 0.75rem;">150 × 86 × 140-180mm</td>
                  <td style="padding: 0.75rem;">120mm to 140mm</td>
                  <td style="padding: 0.75rem;">600mm to 750mm</td>
                </tr>
                <tr style="border-bottom: 1px solid var(--border-subtle);">
                  <td style="padding: 0.75rem; font-weight: 700;">SFX</td>
                  <td style="padding: 0.75rem;">125 × 63.5 × 100mm</td>
                  <td style="padding: 0.75rem;">80mm to 92mm</td>
                  <td style="padding: 0.75rem;">300mm to 400mm</td>
                </tr>
                <tr style="border-bottom: 1px solid var(--border-subtle);">
                  <td style="padding: 0.75rem; font-weight: 700;">SFX-L</td>
                  <td style="padding: 0.75rem;">125 × 63.5 × 125mm</td>
                  <td style="padding: 0.75rem;">120mm</td>
                  <td style="padding: 0.75rem;">300mm to 450mm</td>
                </tr>
              </tbody>
            </table>
          </div>

          <h2 id="cable-length">Cable Length &amp; Mounting Adapters</h2>
          <p>
            Because SFX units are destined for tight spaces, their modular cables are typically 300mm to 400mm long, compared to 600mm+ on standard ATX power supplies.
          </p>
          <div class="important-warning" style="margin: 1.5rem 0; padding: 1rem; background: rgba(245, 158, 11, 0.05); border-left: 4px solid var(--color-warning); border-radius: 4px; font-size: 0.9rem;">
            <strong>⚠ Cabling Tip:</strong> If you install an SFX unit in a Mid-Tower ATX case, the 24-pin motherboard cable or 8-pin EPS CPU cable may not reach their respective sockets. You will need sleeved extension cables or an ATX-length modular cable set in this scenario.
          </div>

          <h2 id="noise">Cooling and Fan Noise Profile</h2>
          <p>
            ATX power supplies can accommodate 120mm to 140mm fans, which move large volumes of air at low RPMs, keeping operation silent. SFX units are limited to 80mm or 92mm fans, which must spin faster (generating a higher-pitched sound profile) to maintain safe thermal limits under heavy loads.
          </p>
        </main>

        <aside class="guide-sidebar">
          <TableOfContents client:load />
          <MethodologyCard />
        </aside>
      </div>
    </div>
  </article>
</Layout>

<style>
  .guide-article { padding: 3rem 0; }
  .guide-header { margin-bottom: 2.5rem; }
  .guide-header h1 { font-size: clamp(2rem, 5vw, 3rem); font-weight: 900; line-height: 1.1; margin-top: 0.5rem; }
  .guide-lead { font-size: 1.2rem; color: var(--color-text-secondary); margin-top: 1rem; line-height: 1.5; }
  .guide-meta { display: flex; gap: 1rem; align-items: center; font-size: 0.8125rem; color: var(--text-tertiary); margin-bottom: 0.75rem; }
  .guide-layout { display: grid; grid-template-columns: 1fr; gap: 3rem; }
  @media (min-width: 1024px) {
    .guide-layout { grid-template-columns: 3fr 1fr; }
  }
  .guide-content h2 { font-size: 1.5rem; font-weight: 800; margin-top: 2rem; margin-bottom: 1rem; border-bottom: 1px solid var(--border-subtle); padding-bottom: 0.5rem; }
  .guide-content p { line-height: 1.6; color: var(--color-text-secondary); margin-bottom: 1.25rem; }
  .guide-content ul { padding-left: 1.5rem; margin-bottom: 1.5rem; }
  .guide-content li { margin-bottom: 0.5rem; color: var(--color-text-secondary); line-height: 1.5; }
</style>
