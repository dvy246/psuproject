---
import Layout from '../../layouts/Layout.astro';
import TableOfContents from '../../components/ui/TableOfContents';
import MethodologyCard from '../../components/ui/MethodologyCard.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "datePublished": "2026-07-13",
  "dateModified": "2026-07-14",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much power does an AIO liquid cooler draw?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "An All-in-One (AIO) liquid cooler typically draws 10W to 25W. This power is split between the pump (5W-10W), radiator fans (2W-4W each), and RGB controller systems."
      }
    },
    {
      "@type": "Question",
      "name": "Can I connect my AIO pump to a standard SYS_FAN header?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It is not recommended. SYS_FAN headers are usually limited to 1.0A (12W), whereas heavy AIO pumps can draw up to 1.5A during motor startup. Plugging a pump into a SYS_FAN header can overload motherboard circuits."
      }
    }
  ]
};
---

<Layout
  title="AIO Liquid Cooler Power Consumption: Pump Headers & Wiring — PSUCheck"
  description="Learn about the power requirements of All-in-One (AIO) liquid coolers. Understand pump amp limits, SATA power cables, and motherboard headers."
  schema={faqSchema}
>
  <article class="guide-article">
    <div class="container">
      <nav class="calc-breadcrumb" aria-label="Breadcrumb" style="margin-bottom: 1.5rem;">
        <a href="/">Home</a>
        <span aria-hidden="true" style="margin: 0 0.5rem; opacity: 0.5;">›</span>
        <a href="/guides/">Guides</a>
        <span aria-hidden="true" style="margin: 0 0.5rem; opacity: 0.5;">›</span>
        <span aria-current="page">AIO Power Draw</span>
      </nav>

      <header class="guide-header">
        <div class="guide-meta">
          <a href="/methodology" class="badge badge-safe" style="text-decoration:none;">✓ Sizing Methodology Verified</a>
          <span>Updated: July 14, 2026</span>
          <span style="margin: 0 0.5rem; opacity: 0.5;">•</span>
          <span class="reading-time-badge">2 min read</span>
        </div>
        <h1>AIO Liquid Cooler Power Draw &amp; Wiring</h1>
        <p class="guide-lead">
          Water cooling pumps and fan hubs add to your system's overall power budget.
          This guide analyzes pump power draw, header limits, and SATA connections.
        </p>
      </header>

      <div class="guide-layout">
        <main class="guide-content" id="main-content">
          <div class="adsense-placeholder" style="margin: 1.5rem 0; padding: 1rem; border: 1px dashed var(--border-subtle); text-align: center; color: var(--text-tertiary); font-size: 0.75rem; border-radius: 4px;">
            ADVERTISEMENT — TOP LEADERBOARD
          </div>

          <h2 id="motherboard-headers">Motherboard Header Power Ratings</h2>
          <p>
            Standard motherboard fan headers (labeled as <strong>SYS_FAN</strong> or <strong>CHA_FAN</strong>) are rated for <strong>1.0 Amp</strong> of current at 12V (equal to 12 Watts). Heavy-duty AIO pumps can draw 0.8A to 1.5A under full startup load.
          </p>
          <p>
            Always plug your pump into the designated <strong>AIO_PUMP</strong> or <strong>W_PUMP</strong> header. These headers are specially rated for up to 2.0A or 3.0A to handle motor startup transients safely without burning out motherboard circuits.
          </p>

          <div class="adsense-placeholder" style="margin: 1.5rem 0; padding: 1rem; border: 1px dashed var(--border-subtle); text-align: center; color: var(--text-tertiary); font-size: 0.75rem; border-radius: 4px;">
            ADVERTISEMENT — IN-CONTENT BANNER
          </div>

          <h2 id="cooling-comparison">Cooler Power Consumption Comparison</h2>
          <p>
            Here is a comparison of typical power requirements across different cooling solutions:
          </p>
          <div style="overflow-x: auto; margin-bottom: 2rem;">
            <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.875rem;">
              <thead>
                <tr style="border-bottom: 2px solid var(--border-subtle); color: var(--text-secondary);">
                  <th style="padding: 0.5rem 0.75rem;">Cooler Type</th>
                  <th style="padding: 0.5rem 0.75rem;">Pump Draw</th>
                  <th style="padding: 0.5rem 0.75rem;">Fan Draw</th>
                  <th style="padding: 0.5rem 0.75rem;">Total Power Draw</th>
                </tr>
              </thead>
              <tbody>
                <tr style="border-bottom: 1px solid var(--border-subtle);">
                  <td style="padding: 0.75rem; font-weight: 700;">Standard Air Cooler (Single Fan)</td>
                  <td style="padding: 0.75rem;">0W</td>
                  <td style="padding: 0.75rem;">2.4W</td>
                  <td style="padding: 0.75rem; font-weight: 700;">2.4W</td>
                </tr>
                <tr style="border-bottom: 1px solid var(--border-subtle);">
                  <td style="padding: 0.75rem; font-weight: 700;">Dual-Tower Air Cooler (Dual Fan)</td>
                  <td style="padding: 0.75rem;">0W</td>
                  <td style="padding: 0.75rem;">4.8W</td>
                  <td style="padding: 0.75rem; font-weight: 700;">4.8W</td>
                </tr>
                <tr style="border-bottom: 1px solid var(--border-subtle);">
                  <td style="padding: 0.75rem; font-weight: 700;">240mm AIO Cooler (Pump + 2x Fans)</td>
                  <td style="padding: 0.75rem;">6.0W</td>
                  <td style="padding: 0.75rem;">4.8W</td>
                  <td style="padding: 0.75rem; font-weight: 700;">10.8W</td>
                </tr>
                <tr style="border-bottom: 1px solid var(--border-subtle);">
                  <td style="padding: 0.75rem; font-weight: 700;">360mm AIO Cooler (Pump + 3x Fans)</td>
                  <td style="padding: 0.75rem;">8.5W</td>
                  <td style="padding: 0.75rem;">7.2W</td>
                  <td style="padding: 0.75rem; font-weight: 700;">15.7W</td>
                </tr>
              </tbody>
            </table>
          </div>

          <h2 id="sata-power">SATA Power Connections</h2>
          <p>
            Many modern high-end AIOs (such as Corsair iCUE Link or NZXT Kraken) bypass motherboard headers for power. Instead, they connect directly to the PSU via a <strong>SATA power connector</strong> or a 6-pin PCIe plug.
          </p>
          <p>
            This ensures the pump and extensive RGB setups have access to a clean 4.5A capacity from the +12V and +5V rails, keeping the motherboard free from overload risks.
          </p>
        </main>

        <aside class="guide-sidebar">
          <TableOfContents client:load />
          <MethodologyCard />
        </aside>
      </div>
    </div>
  </article>
</Layout>

<style>
  .guide-article { padding: 3rem 0; }
  .guide-header { margin-bottom: 2.5rem; }
  .guide-header h1 { font-size: clamp(2rem, 5vw, 3rem); font-weight: 900; line-height: 1.1; margin-top: 0.5rem; }
  .guide-lead { font-size: 1.2rem; color: var(--color-text-secondary); margin-top: 1rem; line-height: 1.5; }
  .guide-meta { display: flex; gap: 1rem; align-items: center; font-size: 0.8125rem; color: var(--text-tertiary); margin-bottom: 0.75rem; }
  .guide-layout { display: grid; grid-template-columns: 1fr; gap: 3rem; }
  @media (min-width: 1024px) {
    .guide-layout { grid-template-columns: 3fr 1fr; }
  }
  .guide-content h2 { font-size: 1.5rem; font-weight: 800; margin-top: 2rem; margin-bottom: 1rem; border-bottom: 1px solid var(--border-subtle); padding-bottom: 0.5rem; }
  .guide-content p { line-height: 1.6; color: var(--color-text-secondary); margin-bottom: 1.25rem; }
</style>
