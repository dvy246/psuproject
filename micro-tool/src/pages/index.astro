---
import Layout from '../layouts/Layout.astro';

const websiteSchema = {
  "@type": "WebApplication",
  "name": "VoltForge PC PSU Calculator",
  "url": "https://voltforge.app",
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Any",
  "description": "Free PC power supply calculator and build cost estimator. Calculates transient power spikes, ATX 3.1 compliance, per-rail analysis, and 5-year TCO.",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "featureList": [
    "PSU wattage recommendation with transient spike modeling",
    "ATX 3.1 compliance checker",
    "PC build cost estimator with pie chart",
    "5-year total cost of ownership calculator",
    "Cable-Melt Prevention Auditor",
    "Per-rail current analysis"
  ]
};

const faqSchema = {
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much PSU wattage do I need for my PC build?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The PSU wattage you need depends on your CPU and GPU power draw plus a safety buffer. A modern RTX 5080 + Ryzen 7 9800X3D system needs at minimum 850W, accounting for the RTX 5080's 540W transient peak plus CPU and other components. VoltForge calculates this precisely using published Cybenetics transient multipliers."
      }
    },
    {
      "@type": "Question",
      "name": "What is ATX 3.1 and do I need it?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "ATX 3.1 is the current power supply standard designed to handle modern GPU transient power spikes of up to 200% of rated wattage for 100 microseconds. It also introduces the 12V-2x6 connector (successor to 12VHPWR) with improved safety. For RTX 5090, 5080, or other high-end GPUs, an ATX 3.1 PSU is strongly recommended."
      }
    },
    {
      "@type": "Question",
      "name": "Why does my GPU need more than its rated TDP from the PSU?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Modern GPUs draw significantly more power in microsecond transient spikes than their rated TBP (Total Board Power). The RTX 5090, for example, is rated at 575W but can spike to 900W+ for sub-millisecond durations. A PSU that can only deliver 575W may trip its over-current protection during these spikes, causing system crashes or shutdowns."
      }
    }
  ]
};
---

<Layout
  title="VoltForge — PC PSU Calculator & Build Cost Estimator"
  description="Free PC power supply calculator with transient spike analysis, ATX 3.1 compliance checker, build cost estimator, and 5-year TCO. Unbiased recommendations based on real Cybenetics data."
  schema={[websiteSchema, faqSchema]}
>

  <!-- ===== HERO SECTION ===== -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-grid"></div>
      <div class="hero-glow hero-glow-1"></div>
      <div class="hero-glow hero-glow-2"></div>
    </div>

    <div class="container hero-inner">
      <div class="hero-badge">
        <span class="badge badge-safe">⚡ Free · Independent · No Manufacturer Bias</span>
      </div>

      <h1 id="hero-heading" class="hero-h1">
        Know Exactly What<br/>
        <span class="gradient-text">Your PC Needs</span>
      </h1>

      <p class="hero-sub">
        The only calculator that models real-world transient power spikes, ATX&nbsp;3.1 compliance,
        and 5-year electricity costs — not just a simple TDP sum.
      </p>

      <div class="hero-ctas">
        <a href="/psu-calculator" class="btn btn-primary" id="cta-psu">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          PSU Calculator
        </a>
        <a href="/pc-builder" class="btn btn-secondary" id="cta-builder">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          Build Cost Calculator
        </a>
      </div>

      <!-- Live stat counters -->
      <div class="hero-stats" aria-label="Calculator statistics">
        <div class="hero-stat">
          <span class="hero-stat-num tabular-nums" id="stat-cpus">23</span>
          <span class="hero-stat-label">Modern CPUs</span>
        </div>
        <div class="hero-stat-divider" aria-hidden="true"></div>
        <div class="hero-stat">
          <span class="hero-stat-num tabular-nums" id="stat-gpus">25</span>
          <span class="hero-stat-label">Modern GPUs</span>
        </div>
        <div class="hero-stat-divider" aria-hidden="true"></div>
        <div class="hero-stat">
          <span class="hero-stat-num tabular-nums" id="stat-psus">35</span>
          <span class="hero-stat-label">PSU Models</span>
        </div>
        <div class="hero-stat-divider" aria-hidden="true"></div>
        <div class="hero-stat">
          <span class="hero-stat-num tabular-nums">7,440+</span>
          <span class="hero-stat-label">Oracle Pages</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== COMPETITOR GAP VISUAL ===== -->
  <section class="gap-section" aria-labelledby="gap-heading">
    <div class="container">
      <div class="section-eyebrow">Why VoltForge?</div>
      <h2 id="gap-heading">Every other tool misses at least two pillars</h2>
      <p style="max-width:58ch;margin-top:0.75rem;">
        PCPartPicker gives prices but no PSU depth. TechSearchers gives PSU depth but no build cost.
        No manufacturer tool is unbiased. VoltForge is the only tool combining all three.
      </p>

      <div class="comparison-table-wrap" role="region" aria-label="Competitor comparison table">
        <table class="comparison-table">
          <thead>
            <tr>
              <th scope="col">Tool</th>
              <th scope="col">Build Cost</th>
              <th scope="col">PSU Depth</th>
              <th scope="col">Guides</th>
              <th scope="col">Unbiased</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>PCPartPicker</td>
              <td class="cell-partial">Partial</td>
              <td class="cell-no">Basic TDP only</td>
              <td class="cell-no">None</td>
              <td class="cell-yes">✓</td>
            </tr>
            <tr>
              <td>TechSearchers</td>
              <td class="cell-no">None</td>
              <td class="cell-yes">✓ Excellent</td>
              <td class="cell-partial">Some</td>
              <td class="cell-yes">✓</td>
            </tr>
            <tr>
              <td>Manufacturer Tools</td>
              <td class="cell-no">None</td>
              <td class="cell-partial">Biased</td>
              <td class="cell-no">None</td>
              <td class="cell-no">Brand-locked</td>
            </tr>
            <tr class="row-voltforge">
              <td><strong>⚡ VoltForge</strong></td>
              <td class="cell-yes">✓ Full + Chart</td>
              <td class="cell-yes">✓ Transients + ATX 3.1</td>
              <td class="cell-yes">✓ 6 Guides</td>
              <td class="cell-yes">✓ Always</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ===== THREE PILLARS ===== -->
  <section class="pillars-section" aria-labelledby="pillars-heading">
    <div class="container">
      <div class="section-eyebrow">What We Calculate</div>
      <h2 id="pillars-heading">Three tools. One place.</h2>

      <div class="pillars-grid">
        <a href="/psu-calculator" class="pillar-card gradient-border" id="pillar-psu">
          <div class="pillar-icon" aria-hidden="true">⚡</div>
          <h3>PSU Deep Analysis</h3>
          <p>
            Goes beyond TDP sum. Models real-world transient spikes using Cybenetics-sourced
            multipliers, checks ATX&nbsp;3.1 compliance, audits cable requirements, and calculates
            5-year electricity costs.
          </p>
          <ul class="pillar-features">
            <li>Transient spike modeling (1.20× – 1.57× TBP)</li>
            <li>ATX 3.1 / 3.0 / 2.x compliance badge</li>
            <li>12V-2x6 cable audit for RTX&nbsp;50-series</li>
            <li>Per-rail current (+12V, +5V, +3.3V)</li>
            <li>5-year TCO comparison across efficiency tiers</li>
          </ul>
          <span class="pillar-cta">Open PSU Calculator →</span>
        </a>

        <a href="/pc-builder" class="pillar-card gradient-border" id="pillar-builder">
          <div class="pillar-icon" aria-hidden="true">🖥️</div>
          <h3>Build Cost Estimator</h3>
          <p>
            Select your components and get an instant total cost with pie chart breakdown,
            per-component percentage allocation, budget advice, and optimization tips.
            All with direct affiliate links.
          </p>
          <ul class="pillar-features">
            <li>23 CPUs × 25 GPUs × 24 motherboards in database</li>
            <li>Pie chart with budget allocation advice</li>
            <li>"Save $X by choosing Y instead" tips</li>
            <li>Tax rate and assembly fee controls</li>
            <li>Shareable build URL</li>
          </ul>
          <span class="pillar-cta">Open PC Builder →</span>
        </a>

        <a href="/guides/how-to-build-a-pc" class="pillar-card gradient-border" id="pillar-guides">
          <div class="pillar-icon" aria-hidden="true">📖</div>
          <h3>Planning Guides</h3>
          <p>
            Six in-depth guides covering every stage of the PC building process — from understanding
            ATX standards to allocating a $1,500 budget. Cross-linked with calculators throughout.
          </p>
          <ul class="pillar-features">
            <li>How to Build a PC — 12-step walkthrough</li>
            <li>ATX 3.1 Guide — connectors, standards, compatibility</li>
            <li>PSU Sizing Guide — debunking wattage myths</li>
            <li>80+ Efficiency Guide — which tier is worth it</li>
            <li>PC Budget Guide — $500 to $2,500 breakdowns</li>
          </ul>
          <span class="pillar-cta">Read the Guides →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== UNIQUE FEATURES SHOWCASE ===== -->
  <section class="features-section" aria-labelledby="features-heading">
    <div class="container">
      <div class="section-eyebrow">Unique to VoltForge</div>
      <h2 id="features-heading">Visuals no other tool shows you</h2>

      <div class="features-grid">
        <!-- Transient Waveform Preview -->
        <div class="feature-card card">
          <div class="feature-visual" aria-hidden="true">
            <div class="waveform-preview">
              <svg viewBox="0 0 300 120" class="waveform-demo-svg" role="img" aria-label="Example transient waveform showing power spike exceeding PSU limit">
                <defs>
                  <linearGradient id="grad-safe" x1="0" y1="0" x2="1" y2="0">
                    <stop offset="0%" stop-color="#00e5ff" stop-opacity="0.8"/>
                    <stop offset="100%" stop-color="#7c4dff" stop-opacity="0.8"/>
                  </linearGradient>
                  <filter id="glow-red">
                    <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
                    <feMerge><feMergeNode in="coloredBlur"/><feMergeNode in="SourceGraphic"/></feMerge>
                  </filter>
                </defs>
                <!-- PSU rating dashed line -->
                <line x1="0" y1="55" x2="300" y2="55" stroke="rgba(255,255,255,0.3)" stroke-width="1" stroke-dasharray="6,4"/>
                <text x="4" y="50" fill="rgba(255,255,255,0.4)" font-size="9" font-family="monospace">850W PSU</text>
                <!-- Continuous load line (blue) -->
                <path d="M 0 90 L 300 90" stroke="#00e5ff" stroke-width="2" fill="none" opacity="0.8"/>
                <text x="4" y="86" fill="#00e5ff" font-size="8" font-family="monospace">360W</text>
                <!-- Area fill under baseline -->
                <path d="M 0 90 L 300 90 L 300 115 L 0 115 Z" fill="rgba(0,229,255,0.05)"/>
                <!-- Spike path (red) -->
                <path d="M 0 90 L 60 90 L 80 90 L 100 45 L 120 90 L 300 90"
                  stroke="#ff1744" stroke-width="2.5" fill="none" filter="url(#glow-red)"
                  class="demo-spike"/>
                <!-- Spike peak label -->
                <text x="105" y="40" fill="#ff1744" font-size="9" font-family="monospace" font-weight="bold">540W peak</text>
                <!-- Time axis -->
                <text x="0" y="118" fill="rgba(255,255,255,0.25)" font-size="8" font-family="monospace">0ms</text>
                <text x="130" y="118" fill="rgba(255,255,255,0.25)" font-size="8" font-family="monospace">50ms</text>
                <text x="262" y="118" fill="rgba(255,255,255,0.25)" font-size="8" font-family="monospace">100ms</text>
              </svg>
            </div>
          </div>
          <h3>Live Transient Waveform</h3>
          <p>
            See exactly how your GPU's power spike compares to your PSU's rated capacity —
            in real time as you change components. The red spike shows the peak transient;
            the dashed line is your PSU limit. No competitor shows this.
          </p>
        </div>

        <!-- Power Gauge Preview -->
        <div class="feature-card card">
          <div class="feature-visual" aria-hidden="true">
            <div class="gauge-preview">
              <svg viewBox="0 0 200 140" role="img" aria-label="Power gauge showing 78% PSU utilization">
                <defs>
                  <linearGradient id="gauge-grad" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#00e5ff"/>
                    <stop offset="100%" stop-color="#7c4dff"/>
                  </linearGradient>
                </defs>
                <!-- Track -->
                <path d="M 30 110 A 70 70 0 0 1 170 110"
                  fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="12" stroke-linecap="round"/>
                <!-- Fill — 78% of arc -->
                <path d="M 30 110 A 70 70 0 0 1 170 110"
                  fill="none" stroke="url(#gauge-grad)" stroke-width="12" stroke-linecap="round"
                  stroke-dasharray="220 282" stroke-dashoffset="0" class="gauge-fill-demo"/>
                <!-- Center text -->
                <text x="100" y="95" text-anchor="middle" fill="white" font-size="28" font-weight="900" font-family="monospace">850W</text>
                <text x="100" y="115" text-anchor="middle" fill="rgba(255,255,255,0.5)" font-size="10" font-family="monospace">RECOMMENDED</text>
                <!-- Labels -->
                <text x="26" y="126" fill="rgba(255,255,255,0.3)" font-size="9" font-family="monospace">0W</text>
                <text x="158" y="126" fill="rgba(255,255,255,0.3)" font-size="9" font-family="monospace">1200W</text>
              </svg>
            </div>
          </div>
          <h3>Animated Power Gauge</h3>
          <p>
            An arc gauge visualizes your recommended PSU wattage within the range of available
            options. Instantly see where your build sits between a 550W budget unit and a
            1,500W flagship — and whether you have headroom for upgrades.
          </p>
        </div>

        <!-- TCO Chart Preview -->
        <div class="feature-card card">
          <div class="feature-visual" aria-hidden="true">
            <div class="tco-preview">
              <div style="display:flex;flex-direction:column;gap:8px;padding:12px 16px;">
                <div style="display:flex;align-items:center;gap:8px;">
                  <span style="font-size:10px;font-family:monospace;color:rgba(255,255,255,0.5);width:60px;">Bronze</span>
                  <div style="flex:1;height:8px;background:rgba(255,255,255,0.08);border-radius:4px;overflow:hidden;">
                    <div style="width:88%;height:100%;background:rgba(255,23,68,0.6);border-radius:4px;"></div>
                  </div>
                  <span style="font-size:10px;font-family:monospace;color:rgba(255,255,255,0.5);width:40px;">$2,190</span>
                </div>
                <div style="display:flex;align-items:center;gap:8px;">
                  <span style="font-size:10px;font-family:monospace;color:rgba(255,255,255,0.5);width:60px;">Gold</span>
                  <div style="flex:1;height:8px;background:rgba(255,255,255,0.08);border-radius:4px;overflow:hidden;">
                    <div style="width:82%;height:100%;background:rgba(255,171,0,0.6);border-radius:4px;"></div>
                  </div>
                  <span style="font-size:10px;font-family:monospace;color:rgba(255,255,255,0.5);width:40px;">$2,040</span>
                </div>
                <div style="display:flex;align-items:center;gap:8px;">
                  <span style="font-size:10px;font-family:monospace;color:rgba(255,255,255,0.5);width:60px;">Platinum</span>
                  <div style="flex:1;height:8px;background:rgba(255,255,255,0.08);border-radius:4px;overflow:hidden;">
                    <div style="width:76%;height:100%;background:rgba(0,230,118,0.7);border-radius:4px;"></div>
                  </div>
                  <span style="font-size:10px;font-family:monospace;color:rgba(0,230,118,0.9);width:40px;">$1,980</span>
                </div>
                <div style="display:flex;align-items:center;gap:8px;">
                  <span style="font-size:10px;font-family:monospace;color:rgba(255,255,255,0.5);width:60px;">Titanium</span>
                  <div style="flex:1;height:8px;background:rgba(255,255,255,0.08);border-radius:4px;overflow:hidden;">
                    <div style="width:71%;height:100%;background:rgba(0,229,255,0.8);border-radius:4px;"></div>
                  </div>
                  <span style="font-size:10px;font-family:monospace;color:rgba(0,229,255,0.9);width:40px;">$1,960</span>
                </div>
                <p style="font-size:9px;color:rgba(0,230,118,0.8);margin-top:4px;font-family:monospace;">✓ Platinum saves $210 vs Bronze over 5 years</p>
              </div>
            </div>
          </div>
          <h3>5-Year Cost Comparison</h3>
          <p>
            See whether upgrading from 80+ Bronze to Platinum actually saves money over 5 years
            when you factor in electricity costs. Enter your kWh rate and usage hours — we show
            exactly when the premium PSU pays for itself.
          </p>
        </div>

        <!-- Cable Audit Preview -->
        <div class="feature-card card">
          <div class="feature-visual" aria-hidden="true">
            <div class="cable-audit-demo cable-warning" style="margin:0;padding:14px 16px;">
              <div style="display:flex;align-items:flex-start;gap:10px;">
                <span style="font-size:1.25rem;flex-shrink:0;">⚠️</span>
                <div>
                  <p style="font-size:0.75rem;font-weight:700;color:#ff1744;margin-bottom:4px;">RTX 5080 DETECTED</p>
                  <p style="font-size:0.7rem;line-height:1.5;color:rgba(255,255,255,0.7);">
                    Requires ATX 3.1 PSU with native <strong>12V-2x6</strong> cable. DO NOT use 8-pin adapters or daisy-chain cables. Using incorrect cabling risks connector overheating.
                  </p>
                </div>
              </div>
            </div>
          </div>
          <h3>Cable-Melt Prevention Audit</h3>
          <p>
            When a high-end GPU is selected, VoltForge instantly audits your cabling requirements
            and warns against dangerous configurations — like daisy-chaining 8-pin adapters on a
            575W RTX 5090. An engineering safety check no other tool provides.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== ORACLE SECTION ===== -->
  <section class="oracle-section" aria-labelledby="oracle-heading">
    <div class="container">
      <div class="oracle-inner">
        <div>
          <div class="section-eyebrow">Programmatic Oracle</div>
          <h2 id="oracle-heading">"Is X watts enough for Y?"<br/> — answered instantly.</h2>
          <p style="max-width:52ch;margin-top:0.75rem;">
            7,440+ pre-built pages answering exact GPU + CPU + wattage combinations.
            Each page includes transient spike analysis, binding constraint identification,
            and three recommended PSUs at budget/mid/premium tiers.
          </p>
          <div style="display:flex;flex-wrap:wrap;gap:0.75rem;margin-top:1.5rem;">
            <a href="/oracle/is-850w-enough-for-rtx-5080" class="oracle-pill">Is 850W enough for RTX 5080?</a>
            <a href="/oracle/is-1000w-enough-for-rtx-5090" class="oracle-pill">Is 1000W enough for RTX 5090?</a>
            <a href="/oracle/is-650w-enough-for-rtx-5070" class="oracle-pill">Is 650W enough for RTX 5070?</a>
            <a href="/oracle/is-750w-enough-for-rx-9070-xt" class="oracle-pill">Is 750W enough for RX 9070 XT?</a>
          </div>
        </div>
        <div class="oracle-visual" aria-hidden="true">
          <div class="oracle-card card-accent">
            <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
              <span class="badge badge-safe" style="font-size:1rem;padding:0.5rem 1rem;">✓ YES</span>
              <span style="font-size:0.875rem;color:var(--text-secondary);">Confidence: 94%</span>
            </div>
            <p style="font-size:1.125rem;font-weight:700;margin-bottom:0.5rem;">850W is enough for RTX 5080 + Ryzen 7 9800X3D</p>
            <p style="font-size:0.875rem;color:var(--text-secondary);">
              Binding constraint: <strong>GPU</strong> (540W transient peak).
              Your 850W PSU leaves 310W of headroom — comfortable margin for ATX 3.1 transient handling.
            </p>
            <div style="margin-top:1rem;padding-top:1rem;border-top:1px solid var(--border-subtle);">
              <p style="font-size:0.75rem;color:var(--text-tertiary);">Top pick: Seasonic FOCUS GX-850 · $149 · Gold · ATX 3.1</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FAQ SECTION (FAQPage schema content) ===== -->
  <section class="faq-section" aria-labelledby="faq-heading">
    <div class="container">
      <div class="section-eyebrow">Common Questions</div>
      <h2 id="faq-heading">Frequently Asked Questions</h2>

      <div class="faq-list">
        <details class="faq-item" id="faq-1">
          <summary class="faq-question">
            How much PSU wattage do I need for my PC build?
            <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="faq-answer">
            <p>
              The PSU wattage you need depends on your CPU and GPU power draw plus a safety buffer.
              A modern RTX&nbsp;5080 + Ryzen&nbsp;7&nbsp;9800X3D system needs at minimum 850W, accounting for
              the RTX&nbsp;5080's 540W transient peak plus CPU and other components. VoltForge calculates
              this precisely using published Cybenetics transient multipliers.
            </p>
          </div>
        </details>

        <details class="faq-item" id="faq-2">
          <summary class="faq-question">
            What is ATX 3.1 and do I need it?
            <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="faq-answer">
            <p>
              ATX 3.1 is the current power supply standard designed to handle modern GPU transient power
              spikes of up to 200% of rated wattage for 100 microseconds. It also introduces the
              12V-2x6 connector (successor to 12VHPWR) with improved safety features. For RTX&nbsp;5090,
              5080, or other high-end GPUs, an ATX&nbsp;3.1 PSU is strongly recommended.
            </p>
          </div>
        </details>

        <details class="faq-item" id="faq-3">
          <summary class="faq-question">
            Why does my GPU need more than its rated TDP from the PSU?
            <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="faq-answer">
            <p>
              Modern GPUs draw significantly more power in microsecond transient spikes than their rated
              TBP (Total Board Power). The RTX&nbsp;5090, for example, is rated at 575W but can spike to
