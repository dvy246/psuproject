---
import Layout from '../layouts/Layout.astro';
import AdSlot from '../components/AdSlot.astro';

const websiteSchema = {
  "@type": "WebApplication",
  "name": "VoltForge PC PSU Calculator",
  "url": "https://voltforge.app",
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Any",
  "description": "Free PC power supply calculator and build cost estimator. Calculates transient power spikes, ATX 3.1 compliance, per-rail analysis, and 5-year TCO.",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "featureList": [
    "PSU wattage recommendation with transient spike modeling",
    "ATX 3.1 compliance checker",
    "PC build cost estimator with pie chart",
    "5-year total cost of ownership calculator",
    "Cable-Melt Prevention Auditor",
    "Per-rail current analysis"
  ]
};

const faqSchema = {
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much PSU wattage do I need for my PC build?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The PSU wattage you need depends on your CPU and GPU power draw plus a safety buffer. A modern RTX 5080 + Ryzen 7 9800X3D system needs at minimum 850W, accounting for the RTX 5080's 540W transient peak plus CPU and other components. VoltForge calculates this precisely using published Cybenetics transient multipliers — not just a simple TDP sum."
      }
    },
    {
      "@type": "Question",
      "name": "What PSU do I need for the RTX 4090?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The RTX 4090 has a 450W TBP but can spike to 707W (1.57× transient multiplier) in sub-millisecond bursts. Paired with a high-end CPU like the Intel i9-14900K (253W sustained), your total transient peak can exceed 960W. NVIDIA officially recommends a minimum 850W PSU, but a 1000W ATX 3.1 PSU with a native 12V-2x6 connector provides the safest margin."
      }
    },
    {
      "@type": "Question",
      "name": "What is ATX 3.1 and do I need it?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "ATX 3.1 is the current power supply standard (2024 revision) designed to handle modern GPU transient power spikes of up to 200% of rated wattage for 100 microseconds. It introduces the 12V-2x6 connector (successor to 12VHPWR) with improved locking and fire-prevention features. For RTX 5090, 5080, RTX 4090, or any GPU above 300W TBP, an ATX 3.1 PSU is strongly recommended."
      }
    },
    {
      "@type": "Question",
      "name": "Is 650W enough for a gaming PC?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "650W is enough for mid-range gaming builds using GPUs up to RTX 4070 or RX 7800 XT paired with a 65W TDP CPU. However, it is NOT sufficient for RTX 4080/4090/5080/5090 class GPUs — these cards have transient peaks of 480W–900W, which can exceed a 650W PSU's instantaneous delivery capacity even if the steady-state draw is lower."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between 80 PLUS Gold, Platinum, and Titanium?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "80 PLUS certifications measure PSU efficiency at 20%, 50%, and 100% load. Gold achieves ≥87–90% efficiency, Platinum achieves ≥89–92%, and Titanium achieves ≥92–96%. In practical terms, a Titanium PSU running 8 hours/day saves roughly $15–25/year in electricity compared to a Bronze unit at US average electricity rates. Over 5 years, Titanium can pay for its premium cost."
      }
    },
    {
      "@type": "Question",
      "name": "Why does my GPU need more than its rated TDP from the PSU?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Modern GPUs draw significantly more power in microsecond transient spikes than their rated TBP (Total Board Power). The RTX 5090, for example, is rated at 575W but can spike to 900W+ for sub-millisecond durations. A PSU that can only deliver 575W continuously may trip its over-current protection during these spikes, causing system crashes, shutdowns, or long-term PSU damage."
      }
    },
    {
      "@type": "Question",
      "name": "How much does it cost to build a gaming PC in 2025?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A budget gaming PC in 2025 costs $500–$800 (Ryzen 5/GTX-class GPU). A mid-range build with RTX 5060 Ti or RX 9070 costs $900–$1,400. A high-end gaming PC with RTX 5080/5090 costs $2,000–$4,000+. These estimates include CPU, GPU, RAM, storage, motherboard, PSU, and case, but not monitor or peripherals."
      }
    },
    {
      "@type": "Question",
      "name": "What PSU do I need for RTX 5090?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The RTX 5090 requires a minimum 1000W PSU according to NVIDIA. With its 575W TBP and a 1.57× transient multiplier, the card can spike to over 900W alone. Combined with a high-end CPU, your total transient peak can exceed 1100W. A 1200W ATX 3.1 PSU with a native 12V-2x6 port (not an adapter) is the safest and recommended configuration."
      }
    },
    {
      "@type": "Question",
      "name": "Should I use a 12VHPWR or 12V-2x6 connector for my GPU?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "If your PSU has both, always use the 12V-2x6 connector — it is the improved successor to 12VHPWR with a better locking mechanism and improved fire resistance. Never use an adapter cable to convert 8-pin PCIe connectors to 12VHPWR/12V-2x6 for high-end GPUs above 350W, as adapters cannot safely handle the transient current demands."
      }
    },
    {
      "@type": "Question",
      "name": "What is a PSU transient spike and why does it matter?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A PSU transient spike is a sudden, extremely brief (sub-millisecond) surge in power demand from a GPU or CPU. Modern NVIDIA RTX 40 and 50-series GPUs can draw 150–200% of their rated TBP for microseconds during workload transitions. If your PSU cannot handle these spikes, it may shut down due to overcurrent protection (OCP) triggering, or degrade faster from repeated capacitor stress."
      }
    },
    {
      "@type": "Question",
      "name": "Is it worth getting a modular PSU?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, a fully modular PSU is worth it for most builds. Modular PSUs let you connect only the cables you need, reducing cable clutter, improving airflow by 5–15%, making installation easier, and enabling custom cable sleeving. The price premium over non-modular units is typically $20–$50 and is well justified for any build above budget tier."
      }
    },
    {
      "@type": "Question",
      "name": "How do I know if my PSU is failing?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Warning signs of a failing PSU include: random system shutdowns under load, PC refusing to power on, coil whine that worsens over time, visible burn marks or melted connectors, burning smell, BSOD errors correlated with GPU-intensive tasks, or voltage readings outside ±5% of rated values. PSUs typically last 5–10 years; replace any unit over 7 years old proactively."
      }
    }
  ]
};
---

<Layout
  title="VoltForge — PC PSU Calculator & Build Cost Estimator"
  description="Free PC power supply calculator with transient spike analysis, ATX 3.1 compliance checker, build cost estimator, and 5-year TCO. Unbiased recommendations based on real Cybenetics data."
  schema={[websiteSchema, faqSchema]}
>

  <!-- ===== HERO SECTION ===== -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-grid"></div>
      <div class="hero-glow hero-glow-1"></div>
      <div class="hero-glow hero-glow-2"></div>
    </div>

    <div class="container hero-inner">
      <div class="hero-left-column">
        <div class="hero-badge">
          <span class="badge badge-safe">⚡ Free · Independent · No Manufacturer Bias</span>
        </div>

        <h1 id="hero-heading" class="hero-h1">
          Know Exactly What<br/>
          <span class="gradient-text">Your PC Needs</span>
        </h1>

        <p class="hero-sub">
          The only calculator that models real-world transient power spikes, ATX&nbsp;3.1 compliance,
          and 5-year electricity costs — not just a simple TDP sum.
        </p>

        <div class="hero-ctas">
          <a href="/psu-calculator" class="btn btn-primary" id="cta-psu">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            PSU Calculator
          </a>
          <a href="/pc-builder" class="btn btn-secondary" id="cta-builder">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            Build Cost Calculator
          </a>
        </div>

        <!-- Live stat counters -->
        <div class="hero-stats" aria-label="Calculator statistics">
          <div class="hero-stat">
            <span class="hero-stat-num tabular-nums" id="stat-cpus">23</span>
            <span class="hero-stat-label">Modern CPUs</span>
          </div>
          <div class="hero-stat-divider" aria-hidden="true"></div>
          <div class="hero-stat">
            <span class="hero-stat-num tabular-nums" id="stat-gpus">25</span>
            <span class="hero-stat-label">Modern GPUs</span>
          </div>
          <div class="hero-stat-divider" aria-hidden="true"></div>
          <div class="hero-stat">
            <span class="hero-stat-num tabular-nums" id="stat-psus">35</span>
            <span class="hero-stat-label">PSU Models</span>
          </div>
          <div class="hero-stat-divider" aria-hidden="true"></div>
          <div class="hero-stat">
            <span class="hero-stat-num tabular-nums">7,440+</span>
            <span class="hero-stat-label">Oracle Pages</span>
          </div>
        </div>
      </div>

      <div class="hero-right-column">
        <div class="hero-visual-wrapper">
          <div class="hero-visual-glow" aria-hidden="true"></div>
          
          <div class="cpu-3d-scene" id="cpu-scene" style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; perspective: 1200px; background: rgba(10, 15, 30, 0.4); border: 1px solid rgba(0, 229, 255, 0.15); border-radius: var(--radius-lg); position: relative; overflow: hidden; box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.05); backdrop-filter: blur(12px); z-index: 1;">
            
            <div class="telemetry-grid" aria-hidden="true">
              <div class="telemetry-line">SYS.READY: +12V_LINE_STABLE</div>
              <div class="telemetry-line">ATX_3.1_AUDIT: OK</div>
              <div class="telemetry-line">VOLTAGE_RIPPLE: &lt;15mV</div>
            </div>
            
            <div class="cpu-package">
              <!-- PCB Board Base -->
              <div class="cpu-pcb">
                <div class="pcb-contacts gold-contacts-lt"></div>
                <div class="pcb-contacts gold-contacts-rt"></div>
                <div class="pcb-contacts gold-contacts-lb"></div>
                <div class="pcb-contacts gold-contacts-rb"></div>
                <div class="pcb-tracers"></div>

                <!-- Integrated Heat Spreader (IHS) -->
                <div class="cpu-ihs">
                  <div class="ihs-surface">
                    <div class="cpu-branding">
                      <span class="brand-class">VOLTFORGE CORE</span>
                      <span class="brand-model">VF-9800X3D</span>
                      <span class="brand-spec">TRANS.MULTIPLIER: 2.1x</span>
                    </div>
                    <div class="ihs-core-glow"></div>
                  </div>
                </div>
              </div>
            </div>

            <div class="circular-diagnostics" aria-hidden="true">
              <svg class="diag-ring" viewBox="0 0 100 100">
                <circle cx="50" cy="50" r="45" stroke="#00e5ff" stroke-width="1.5" fill="none" stroke-dasharray="283" stroke-dashoffset="75" />
              </svg>
              <div class="diag-text">DIAG_READY</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    function initCpuInteraction() {
      const scene = document.getElementById('cpu-scene');
      const pkg = scene?.querySelector('.cpu-package');
      if (!scene || !pkg) return;

      let rx = 22;
      let ry = -22;
      let isDragging = false;
      let startX = 0;
      let startY = 0;

      // Mouse hover tilt effect
      scene.addEventListener('mousemove', (e) => {
        if (isDragging) return;
        const rect = scene.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        
        const currentRy = (x / (rect.width / 2)) * 35; 
        const currentRx = -(y / (rect.height / 2)) * 35; 

        pkg.style.setProperty('--rx', `${currentRx}deg`);
        pkg.style.setProperty('--ry', `${currentRy}deg`);
      });

      scene.addEventListener('mouseleave', () => {
        if (isDragging) return;
        pkg.style.setProperty('--rx', '22deg');
        pkg.style.setProperty('--ry', '-22deg');
      });

      // Mouse drag rotation support
      scene.addEventListener('mousedown', (e) => {
        isDragging = true;
        startX = e.clientX;
        startY = e.clientY;
        pkg.style.transition = 'none';
      });

      window.addEventListener('mousemove', (e) => {
        if (!isDragging) return;
        const dx = e.clientX - startX;
        const dy = e.clientY - startY;

        ry += dx * 0.5;
        rx -= dy * 0.5;

        pkg.style.setProperty('--rx', `${rx}deg`);
        pkg.style.setProperty('--ry', `${ry}deg`);

        startX = e.clientX;
        startY = e.clientY;
      });

      window.addEventListener('mouseup', () => {
        if (!isDragging) return;
        isDragging = false;
        pkg.style.transition = 'transform 0.5s ease-out';
      });

      // Touch drag support
      scene.addEventListener('touchstart', (e) => {
        isDragging = true;
        startX = e.touches[0].clientX;
        startY = e.touches[0].clientY;
        pkg.style.transition = 'none';
      });

      scene.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
        const dx = e.touches[0].clientX - startX;
        const dy = e.touches[0].clientY - startY;

        ry += dx * 0.5;
        rx -= dy * 0.5;

        pkg.style.setProperty('--rx', `${rx}deg`);
        pkg.style.setProperty('--ry', `${ry}deg`);

        startX = e.touches[0].clientX;
        startY = e.touches[0].clientY;
      });

      scene.addEventListener('touchend', () => {
        isDragging = false;
        pkg.style.transition = 'transform 0.5s ease-out';
      });
    }

    initCpuInteraction();
    document.addEventListener('astro:after-swap', initCpuInteraction);
  </script>

  <!-- ===== COMPETITOR GAP VISUAL ===== -->
  <section class="gap-section" aria-labelledby="gap-heading">
    <div class="container">
      <div class="section-eyebrow">Why VoltForge?</div>
      <h2 id="gap-heading">Every other tool misses at least two pillars</h2>
      <p style="max-width:58ch;margin-top:0.75rem;">
        PCPartPicker gives prices but no PSU depth. TechSearchers gives PSU depth but no build cost.
        No manufacturer tool is unbiased. VoltForge is the only tool combining all three.
      </p>

      <div class="comparison-table-wrap" role="region" aria-label="Competitor comparison table">
        <table class="comparison-table">
          <thead>
            <tr>
              <th scope="col">Tool</th>
              <th scope="col">Build Cost</th>
              <th scope="col">PSU Depth</th>
              <th scope="col">Guides</th>
              <th scope="col">Unbiased</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>PCPartPicker</td>
              <td class="cell-partial">Partial</td>
              <td class="cell-no">Basic TDP only</td>
              <td class="cell-no">None</td>
              <td class="cell-yes">✓</td>
            </tr>
            <tr>
              <td>TechSearchers</td>
              <td class="cell-no">None</td>
              <td class="cell-yes">✓ Excellent</td>
              <td class="cell-partial">Some</td>
              <td class="cell-yes">✓</td>
            </tr>
            <tr>
              <td>Manufacturer Tools</td>
              <td class="cell-no">None</td>
              <td class="cell-partial">Biased</td>
              <td class="cell-no">None</td>
              <td class="cell-no">Brand-locked</td>
            </tr>
            <tr class="row-voltforge">
              <td><strong>⚡ VoltForge</strong></td>
              <td class="cell-yes">✓ Full + Chart</td>
              <td class="cell-yes">✓ Transients + ATX 3.1</td>
              <td class="cell-yes">✓ 6 Guides</td>
              <td class="cell-yes">✓ Always</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ===== THREE PILLARS ===== -->
  <section class="pillars-section" aria-labelledby="pillars-heading">
    <div class="container">
      <div class="section-eyebrow">What We Calculate</div>
      <h2 id="pillars-heading">Three tools. One place.</h2>

      <div class="pillars-grid">
        <a href="/psu-calculator" class="pillar-card gradient-border" id="pillar-psu">
          <div class="pillar-icon" aria-hidden="true">⚡</div>
          <h3>PSU Deep Analysis</h3>
          <p>
            Goes beyond TDP sum. Models real-world transient spikes using Cybenetics-sourced
            multipliers, checks ATX&nbsp;3.1 compliance, audits cable requirements, and calculates
            5-year electricity costs.
          </p>
          <ul class="pillar-features">
            <li>Transient spike modeling (1.20× – 1.57× TBP)</li>
            <li>ATX 3.1 / 3.0 / 2.x compliance badge</li>
            <li>12V-2x6 cable audit for RTX&nbsp;50-series</li>
            <li>Per-rail current (+12V, +5V, +3.3V)</li>
            <li>5-year TCO comparison across efficiency tiers</li>
          </ul>
          <span class="pillar-cta">Open PSU Calculator →</span>
        </a>

        <a href="/pc-builder" class="pillar-card gradient-border" id="pillar-builder">
          <div class="pillar-icon" aria-hidden="true">🖥️</div>
          <h3>Build Cost Estimator</h3>
          <p>
            Select your components and get an instant total cost with pie chart breakdown,
            per-component percentage allocation, budget advice, and optimization tips.
            All with direct affiliate links.
          </p>
          <ul class="pillar-features">
            <li>23 CPUs × 25 GPUs × 24 motherboards in database</li>
            <li>Pie chart with budget allocation advice</li>
            <li>"Save $X by choosing Y instead" tips</li>
            <li>Tax rate and assembly fee controls</li>
            <li>Shareable build URL</li>
          </ul>
          <span class="pillar-cta">Open PC Builder →</span>
        </a>

        <a href="/guides/how-to-build-a-pc" class="pillar-card gradient-border" id="pillar-guides">
          <div class="pillar-icon" aria-hidden="true">📖</div>
          <h3>Planning Guides</h3>
          <p>
            Six in-depth guides covering every stage of the PC building process — from understanding
            ATX standards to allocating a $1,500 budget. Cross-linked with calculators throughout.
          </p>
          <ul class="pillar-features">
            <li>How to Build a PC — 12-step walkthrough</li>
            <li>ATX 3.1 Guide — connectors, standards, compatibility</li>
            <li>PSU Sizing Guide — debunking wattage myths</li>
            <li>80+ Efficiency Guide — which tier is worth it</li>
            <li>PC Budget Guide — $500 to $2,500 breakdowns</li>
          </ul>
          <span class="pillar-cta">Read the Guides →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== UNIQUE FEATURES SHOWCASE ===== -->
  <section class="features-section" aria-labelledby="features-heading">
    <div class="container">
      <div class="section-eyebrow">Unique to VoltForge</div>
      <h2 id="features-heading">Visuals no other tool shows you</h2>

      <div class="features-grid">
        <!-- Transient Waveform Preview -->
        <div class="feature-card card">
          <div class="feature-visual" aria-hidden="true">
            <div class="waveform-preview">
              <svg viewBox="0 0 300 120" class="waveform-demo-svg" role="img" aria-label="Example transient waveform showing power spike exceeding PSU limit">
                <defs>
                  <linearGradient id="grad-safe" x1="0" y1="0" x2="1" y2="0">
                    <stop offset="0%" stop-color="#00e5ff" stop-opacity="0.8"/>
                    <stop offset="100%" stop-color="#7c4dff" stop-opacity="0.8"/>
                  </linearGradient>
                  <filter id="glow-red">
                    <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
                    <feMerge><feMergeNode in="coloredBlur"/><feMergeNode in="SourceGraphic"/></feMerge>
                  </filter>
                </defs>
                <!-- PSU rating dashed line -->
                <line x1="0" y1="55" x2="300" y2="55" stroke="rgba(255,255,255,0.3)" stroke-width="1" stroke-dasharray="6,4"/>
                <text x="4" y="50" fill="rgba(255,255,255,0.4)" font-size="9" font-family="monospace">850W PSU</text>
                <!-- Continuous load line (blue) -->
                <path d="M 0 90 L 300 90" stroke="#00e5ff" stroke-width="2" fill="none" opacity="0.8"/>
                <text x="4" y="86" fill="#00e5ff" font-size="8" font-family="monospace">360W</text>
                <!-- Area fill under baseline -->
                <path d="M 0 90 L 300 90 L 300 115 L 0 115 Z" fill="rgba(0,229,255,0.05)"/>
                <!-- Spike path (red) -->
                <path d="M 0 90 L 60 90 L 80 90 L 100 45 L 120 90 L 300 90"
                  stroke="#ff1744" stroke-width="2.5" fill="none" filter="url(#glow-red)"
                  class="demo-spike"/>
                <!-- Spike peak label -->
                <text x="105" y="40" fill="#ff1744" font-size="9" font-family="monospace" font-weight="bold">540W peak</text>
                <!-- Time axis -->
                <text x="0" y="118" fill="rgba(255,255,255,0.25)" font-size="8" font-family="monospace">0ms</text>
                <text x="130" y="118" fill="rgba(255,255,255,0.25)" font-size="8" font-family="monospace">50ms</text>
                <text x="262" y="118" fill="rgba(255,255,255,0.25)" font-size="8" font-family="monospace">100ms</text>
              </svg>
            </div>
          </div>
          <h3>Live Transient Waveform</h3>
          <p>
            See exactly how your GPU's power spike compares to your PSU's rated capacity —
            in real time as you change components. The red spike shows the peak transient;
            the dashed line is your PSU limit. No competitor shows this.
          </p>
        </div>

        <!-- Power Gauge Preview -->
        <div class="feature-card card">
          <div class="feature-visual" aria-hidden="true">
            <div class="gauge-preview">
              <svg viewBox="0 0 200 140" role="img" aria-label="Power gauge showing 78% PSU utilization">
                <defs>
                  <linearGradient id="gauge-grad" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#00e5ff"/>
                    <stop offset="100%" stop-color="#7c4dff"/>
                  </linearGradient>
                </defs>
                <!-- Track -->
                <path d="M 30 110 A 70 70 0 0 1 170 110"
                  fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="12" stroke-linecap="round"/>
                <!-- Fill — 78% of arc -->
                <path d="M 30 110 A 70 70 0 0 1 170 110"
                  fill="none" stroke="url(#gauge-grad)" stroke-width="12" stroke-linecap="round"
                  stroke-dasharray="220 282" stroke-dashoffset="0" class="gauge-fill-demo"/>
                <!-- Center text -->
                <text x="100" y="95" text-anchor="middle" fill="white" font-size="28" font-weight="900" font-family="monospace">850W</text>
                <text x="100" y="115" text-anchor="middle" fill="rgba(255,255,255,0.5)" font-size="10" font-family="monospace">RECOMMENDED</text>
                <!-- Labels -->
                <text x="26" y="126" fill="rgba(255,255,255,0.3)" font-size="9" font-family="monospace">0W</text>
                <text x="158" y="126" fill="rgba(255,255,255,0.3)" font-size="9" font-family="monospace">1200W</text>
              </svg>
            </div>
          </div>
          <h3>Animated Power Gauge</h3>
