---
import Layout from '../../layouts/Layout.astro';
import buildsData from '../../data/builds.json';
import cpuData from '../../data/index/cpus.index.json';
import gpuData from '../../data/index/gpus.index.json';
import psuData from '../../data/index/psus.index.json';

// Map component IDs to names
const cpus = new Map(cpuData.items.map(c => [c.id, c.name]));
const gpus = new Map(gpuData.items.map(g => [g.id, g.name]));
const psus = new Map(psuData.items.map(p => [p.id, p.name]));

const builds = buildsData.items;

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "PSUCheck PC Builds Gallery",
  "url": "https://psucheck.com/builds",
  "description": "Browse community PC builds with complete component lists and real-time transient-aware PSU safety analysis.",
  "itemListElement": builds.map((b, idx) => ({
    "@type": "ListItem",
    "position": idx + 1,
    "name": b.name,
    "url": `https://psucheck.com/build/${b.slug}`
  }))
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the PSUCheck Completed Builds Gallery?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It is a community-driven database of completed PC configurations. Each build includes detailed specs, prices, and advanced PSU compatibility diagnostics like transient peak spikes and ATX 3.1 compliance."
      }
    },
    {
      "@type": "Question",
      "name": "How can I share my PC build on PSUCheck?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Configure your PC in our builder, open the Share dialog, click 'Publish to Gallery', fill out a short description of at least 150 characters, and submit it. Your build will be saved to your local gallery and queued for moderation."
      }
    }
  ]
};
---

<Layout
  title="Completed PC Builds: Gallery & PSU Diagnostics — PSUCheck"
  description="Explore community completed PC builds. View actual component specs, hardware cost distribution charts, transient power peak spikes, and cable audit alerts."
  schema={[schema, faqSchema]}
>
  <section class="gallery-hero" aria-labelledby="gallery-heading">
    <div class="container">
      <div class="calc-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Builds Gallery</span>
      </div>
      <header style="margin-top:1.5rem; margin-bottom:2rem;">
        <h1 id="gallery-heading" style="font-size:clamp(2rem, 5vw, 3rem); font-weight:850; line-height:1.1; letter-spacing:-0.03em;">
          Community <span class="gradient-text">Build Gallery</span>
        </h1>
        <p style="font-size:1.1rem; color:var(--color-text-secondary); max-width:600px; margin-top:0.75rem; line-height:1.6;">
          Real configurations designed by PC enthusiasts, each analyzed with sub-millisecond transient power spikes, ATX 3.1 criteria, and pricing details.
        </p>
      </header>
    </div>
  </section>

  <!-- Interactive Client-side filter container & Local Builds mounting -->
  <section style="padding-bottom:6rem;">
    <div class="container">
      
      {/* ── Tabs for Public vs Local Builds ── */}
      <div class="gallery-tabs" style="display:flex; gap:1rem; border-bottom:1px solid var(--color-border-subtle); margin-bottom:2rem;">
        <button class="tab-btn active" id="tab-public" style="padding:0.75rem 1rem; background:transparent; border:none; border-bottom:2px solid var(--color-accent-cyan); color:var(--color-text-primary); font-weight:700; cursor:pointer; font-size:0.95rem;">
          Public Gallery ({builds.length})
        </button>
        <button class="tab-btn" id="tab-local" style="padding:0.75rem 1rem; background:transparent; border:none; border-bottom:2px solid transparent; color:var(--color-text-tertiary); font-weight:600; cursor:pointer; font-size:0.95rem;">
          My Saved Builds (<span id="local-count">0</span>)
        </button>
      </div>

      {/* ── Public Gallery Grid ── */}
      <div id="public-gallery-view">
        <div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap:1.5rem;">
          {builds.map(b => (
            <div class="card card-dark" style="display:flex; flex-direction:column; justify-content:space-between; padding:1.5rem; border:1px solid var(--color-border-subtle); border-radius:var(--radius-lg); position:relative; overflow:hidden;">
              <div>
                <div style="display:flex; justify-content:space-between; align-items:center;">
                  <span style="font-size:0.75rem; font-weight:700; color:var(--color-text-tertiary); text-transform:uppercase;">@{b.creator}</span>
                  <span class="badge badge-safe" style="font-size:0.7rem; text-transform:uppercase;">{b.useCase}</span>
                </div>
                
                <h2 style="font-size:1.15rem; font-weight:700; margin-top:0.5rem; line-height:1.3; color:var(--color-text-primary);">
                  <a href={`/build/${b.slug}`} style="color:inherit; text-decoration:none; outline:none;" class="hover-cyan">{b.name}</a>
                </h2>
                
                <p style="font-size:0.8125rem; color:var(--color-text-secondary); line-height:1.5; margin-top:0.75rem; margin-bottom:1.25rem; display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden;">
                  {b.description}
                </p>

                <div style="display:flex; flex-direction:column; gap:0.5rem; font-size:0.8125rem; color:var(--color-text-secondary); border-top:1px solid var(--color-border-subtle); padding-top:0.75rem;">
                  <div style="display:flex; justify-content:space-between;">
                    <span>CPU:</span>
                    <strong style="color:var(--color-text-primary);">{cpus.get(b.cpuId) || b.cpuId}</strong>
                  </div>
                  <div style="display:flex; justify-content:space-between;">
                    <span>GPU:</span>
                    <strong style="color:var(--color-text-primary);">{gpus.get(b.gpuId) || b.gpuId}</strong>
                  </div>
                  <div style="display:flex; justify-content:space-between;">
                    <span>Power Supply:</span>
                    <strong style="color:var(--color-text-primary);">{psus.get(b.psuId) || b.psuId}</strong>
                  </div>
                </div>
              </div>

              <div style="display:flex; justify-content:space-between; align-items:center; margin-top:1.5rem; border-top:1px solid var(--color-border-subtle); padding-top:0.75rem;">
                <div style="display:flex; flex-direction:column;">
                  <span style="font-size:0.65rem; color:var(--color-text-tertiary); text-transform:uppercase;">Build Cost</span>
                  <span style="font-size:1.25rem; font-weight:800; color:var(--color-accent-cyan); font-family:var(--font-mono);">${b.price}</span>
                </div>
                <a href={`/build/${b.slug}`} class="btn btn-secondary" style="font-size:0.75rem; padding:6px 12px; min-height:34px; text-decoration:none; display:inline-flex; align-items:center;">
                  View Diagnostics →
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>

      {/* ── Local Builds Grid (Client-side populated) ── */}
      <div id="local-gallery-view" style="display:none;">
        <div id="local-empty-state" style="text-align:center; padding:3rem 1rem;">
          <div style="font-size:2.5rem; color:var(--color-text-tertiary); margin-bottom:1rem;">📂</div>
          <h3 style="font-size:1.1rem; font-weight:700; color:var(--color-text-secondary);">No Saved Builds Yet</h3>
          <p style="font-size:0.875rem; color:var(--color-text-tertiary); margin-top:0.25rem; max-width:320px; margin-left:auto; margin-right:auto;">
            Configure a build in the workbench and click 'Publish to Gallery' inside the Share modal to save it.
          </p>
          <a href="/psu-calculator" class="btn btn-primary" style="margin-top:1.5rem; text-decoration:none; display:inline-flex; align-items:center; font-size:0.8125rem;">
            Go to Workbench
          </a>
        </div>
        <div id="local-builds-grid" style="display:grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap:1.5rem;"></div>
      </div>

    </div>
  </section>
</Layout>

<script>
  // Tab Switching Logic
  const tabPublic = document.getElementById('tab-public');
  const tabLocal = document.getElementById('tab-local');
  const publicView = document.getElementById('public-gallery-view');
  const localView = document.getElementById('local-gallery-view');
  const localCount = document.getElementById('local-count');
  const localEmpty = document.getElementById('local-empty-state');
  const localGrid = document.getElementById('local-builds-grid');

  function renderLocalBuilds() {
    try {
      const stored = localStorage.getItem('psucheck_my_builds');
      const builds = stored ? JSON.parse(stored) : [];
      
      if (localCount) localCount.textContent = builds.length;
      
      if (builds.length === 0) {
        if (localEmpty) localEmpty.style.display = 'block';
        if (localGrid) localGrid.innerHTML = '';
      } else {
        if (localEmpty) localEmpty.style.display = 'none';
        if (localGrid) {
          localGrid.innerHTML = builds.map(b => `
            <div class="card card-dark" style="display:flex; flex-direction:column; justify-content:space-between; padding:1.5rem; border:1px solid var(--color-border-subtle); border-radius:var(--radius-lg);">
              <div>
                <div style="display:flex; justify-content:space-between; align-items:center;">
                  <span style="font-size:0.75rem; font-weight:700; color:var(--color-text-tertiary); text-transform:uppercase;">@\${b.creator} (You)</span>
                  <span class="badge badge-safe" style="font-size:0.7rem; text-transform:uppercase;">\${b.useCase}</span>
                </div>
                
                <h2 style="font-size:1.15rem; font-weight:700; margin-top:0.5rem; line-height:1.3; color:var(--color-text-primary);">
                  \${b.name}
                </h2>
                
                <p style="font-size:0.8125rem; color:var(--color-text-secondary); line-height:1.5; margin-top:0.75rem; margin-bottom:1.25rem;">
                  \${b.description}
                </p>

                <div style="display:flex; flex-direction:column; gap:0.5rem; font-size:0.8125rem; color:var(--color-text-secondary); border-top:1px solid var(--color-border-subtle); padding-top:0.75rem;">
                  <div style="display:flex; justify-content:space-between;">
                    <span>Target Target Target Resolution:</span>
                    <strong style="color:var(--color-text-primary);">\${b.resolution}</strong>
                  </div>
                </div>
              </div>

              <div style="display:flex; justify-content:space-between; align-items:center; margin-top:1.5rem; border-top:1px solid var(--color-border-subtle); padding-top:0.75rem;">
                <div style="display:flex; flex-direction:column;">
                  <span style="font-size:0.65rem; color:var(--color-text-tertiary); text-transform:uppercase;">Build Cost</span>
                  <span style="font-size:1.25rem; font-weight:800; color:var(--color-accent-cyan); font-family:var(--font-mono);">\$\${b.price}</span>
                </div>
                <button class="btn btn-secondary btn-load-build" data-build-id="\${b.slug}" style="font-size:0.75rem; padding:6px 12px; min-height:34px;">
                  Load to Workbench
                </button>
              </div>
            </div>
          `).join('');

          // Bind Load Buttons
          document.querySelectorAll('.btn-load-build').forEach(btn => {
            btn.addEventListener('click', (e) => {
              const buildId = (e.currentTarget as HTMLButtonElement).getAttribute('data-build-id');
              const match = builds.find(item => item.slug === buildId);
              if (match) {
                // Construct search query mimicking url.ts serializations
                // Format: ?cpu=id&gpu=id&mobo=id...
                const params = new URLSearchParams();
                if (match.cpuId) params.append('cpu', match.cpuId);
                if (match.gpuId) params.append('gpu', match.gpuId);
                if (match.moboId) params.append('mobo', match.moboId);
                window.location.href = `/psu-calculator?\${params.toString()}`;
              }
            });
          });
        }
      }
    } catch (e) {
      console.error('Failed to load local builds', e);
    }
  }

  // Initial load
  renderLocalBuilds();

  tabPublic?.addEventListener('click', () => {
    tabPublic.classList.add('active');
    tabPublic.style.color = 'var(--color-text-primary)';
    tabPublic.style.borderBottomColor = 'var(--color-accent-cyan)';
    
    tabLocal?.classList.remove('active');
    if (tabLocal) {
      tabLocal.style.color = 'var(--color-text-tertiary)';
      tabLocal.style.borderBottomColor = 'transparent';
    }
    
    if (publicView) publicView.style.display = 'block';
    if (localView) localView.style.display = 'none';
  });

  tabLocal?.addEventListener('click', () => {
    tabLocal.classList.add('active');
    tabLocal.style.color = 'var(--color-text-primary)';
    tabLocal.style.borderBottomColor = 'var(--color-accent-cyan)';
    
    tabPublic?.classList.remove('active');
    if (tabPublic) {
      tabPublic.style.color = 'var(--color-text-tertiary)';
      tabPublic.style.borderBottomColor = 'transparent';
    }
    
    if (publicView) publicView.style.display = 'none';
    if (localView) localView.style.display = 'block';
    renderLocalBuilds();
  });
</script>

<style>
  .gallery-hero {
    padding: 3rem 0 1rem;
  }
  .hover-cyan:hover {
    color: var(--color-accent-cyan) !important;
    transition: color 200ms ease;
  }
</style>
