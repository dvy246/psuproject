---
import Layout from '../../../../../../../layouts/Layout.astro';
import { checkGpuPsu } from '../../../../../../../lib/compatibility/check-gpu-psu';

import gpuData from '../../../../../../../data/index/gpus.index.json';
import psuData from '../../../../../../../data/index/psus.index.json';

export async function getStaticPaths() {
  const gpus = gpuData.items;
  const psus = psuData.items;
  const ages = ['3', '5', '8', '10', '12'];
  const paths = [];

  for (const gpu of gpus) {
    for (const psu of psus) {
      for (const years of ages) {
        paths.push({
          params: { gpu: gpu.id, psu: psu.id, years },
          props: { gpu, psu, ageYears: Number(years) }
        });
      }
    }
  }
  return paths;
}

const { gpu, psu, ageYears } = Astro.props;
const result = checkGpuPsu(gpu as any, psu as any, { ageYears });

const pageTitle = `Is a ${ageYears} Year Old ${psu.name} Safe for the ${gpu.name}? — PSUCheck`;
const pageDescription = `Audit capacitor degradation and transient sizing safety for powering the ${gpu.name} with a ${ageYears} year old ${psu.name}.`;
---

<Layout
  title={pageTitle}
  description={pageDescription}
>
  <section class="compat-page" style="padding: 3rem 0 6rem;">
    <div class="container">
      <nav class="calc-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true" style="margin: 0 0.5rem; opacity: 0.5;">›</span>
        <a href="/compatibility/">Compatibility</a>
        <span aria-hidden="true" style="margin: 0 0.5rem; opacity: 0.5;">›</span>
        <span aria-current="page">{gpu.name} to {psu.name} ({ageYears}yr)</span>
      </nav>

      <header style="margin-bottom: 2.5rem; margin-top: 1.5rem;">
        <span style="font-size: 0.75rem; font-weight: 700; color: var(--color-accent-cyan); text-transform: uppercase; letter-spacing: 0.1em; display: block; margin-bottom: 0.5rem;">Capacitor Aging Sizing</span>
        <h1 style="font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 900; margin: 0 0 1rem; line-height: 1.15;">
          PSU Health Check: <span class="gradient-text">{ageYears} Year Old {psu.name}</span> with <span class="gradient-text">{gpu.name}</span>
        </h1>
      </header>

      {/* Verdict Panel */}
      <div class="card" style={`padding: 1.5rem; border-left: 4px solid ${result.verdict === 'PASS' ? 'var(--color-safe)' : result.verdict === 'WARN' ? 'var(--color-warning)' : 'var(--color-danger)'}; margin-bottom: 2.5rem;`}>
        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
          <span class={`badge ${result.verdict === 'PASS' ? 'badge-safe' : result.verdict === 'WARN' ? 'badge-warning' : 'badge-danger'}`} style="font-size: 0.85rem; padding: 4px 10px;">
            {result.verdict === 'PASS' ? 'Safe & Compatible' : result.verdict === 'WARN' ? 'Caution / Borderline' : 'Incompatible / Upgrade Required'}
          </span>
        </div>
        <p style="font-size: 1rem; line-height: 1.6; color: var(--color-text-primary);">
          {result.verdict === 'PASS' ? (
            <span>Yes! Your <strong>{ageYears} year old {psu.name}</strong> retains enough effective capacity (<strong>{result.details.effectiveCapacity}W</strong> after aging derating) to safely handle the <strong>{gpu.name}</strong>.</span>
          ) : result.verdict === 'WARN' ? (
            <span>Caution. Capacitor degradation has reduced your PSU's effective capacity to <strong>{result.details.effectiveCapacity}W</strong>. Running the <strong>{gpu.name}</strong> is borderline.</span>
          ) : (
            <span>No. Your <strong>{ageYears} year old {psu.name}</strong> is no longer safe to pair with the <strong>{gpu.name}</strong>. Effective capacity has dropped to <strong>{result.details.effectiveCapacity}W</strong>, which is insufficient for the upgraded peak transient load.</span>
          )}
        </p>

        {result.warnings.map(w => (
          <div style="margin-top: 0.75rem; color: var(--color-warning-text); font-size: 0.875rem;">⚠️ {w}</div>
        ))}
        {result.failures.map(f => (
          <div style="margin-top: 0.75rem; color: var(--color-danger-text); font-size: 0.875rem;">❌ {f}</div>
        ))}
      </div>

      {/* Details Table */}
      <div class="card" style="padding: 1.5rem; border: 1px solid var(--border-subtle); border-radius: var(--radius-lg); margin-bottom: 3rem;">
        <h2 style="font-size: 1.15rem; font-weight: 800; color: var(--text-primary); margin: 0 0 1.25rem; text-transform: uppercase; letter-spacing: 0.05em;">Capacitor Aging Calculations</h2>
        <div style="overflow-x: auto;">
          <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.875rem;">
            <thead>
              <tr style="border-bottom: 2px solid var(--border-subtle); color: var(--text-secondary);">
                <th style="padding: 0.5rem 0.75rem;">Metric</th>
                <th style="padding: 0.5rem 0.75rem;">Calculated Value</th>
                <th style="padding: 0.5rem 0.75rem;">Base Spec</th>
              </tr>
            </thead>
            <tbody>
              <tr style="border-bottom: 1px solid var(--border-subtle);">
                <td style="padding: 0.75rem; font-weight: 700;">PSU Rated Wattage</td>
                <td style="padding: 0.75rem;">{psu.wattage}W</td>
                <td style="padding: 0.75rem;">—</td>
              </tr>
              <tr style="border-bottom: 1px solid var(--border-subtle);">
                <td style="padding: 0.75rem; font-weight: 700;">Estimated Capacity Loss</td>
                <td style="padding: 0.75rem; color: var(--color-danger-text);">{Math.round(result.details.agingLossFactor * 100)}%</td>
                <td style="padding: 0.75rem;">5% annually after year 3</td>
              </tr>
              <tr style="border-bottom: 1px solid var(--border-subtle);">
                <td style="padding: 0.75rem; font-weight: 700;">Effective Output Capacity</td>
                <td style="padding: 0.75rem; font-weight: 700; color: var(--color-safe);">{result.details.effectiveCapacity}W</td>
                <td style="padding: 0.75rem;">—</td>
              </tr>
              <tr style="border-bottom: 1px solid var(--border-subtle);">
                <td style="padding: 0.75rem; font-weight: 700;">Upgraded Transient Peak</td>
                <td style="padding: 0.75rem; color: var(--color-warning-text);">{result.details.transientPeak}W</td>
                <td style="padding: 0.75rem;">Steady-state: {result.details.baseDraw}W</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>
</Layout>
