---
import Layout from '../../../../../layouts/Layout.astro';
import { checkCoolerCase } from '../../../../../lib/compatibility/check-cooler-case';

import coolerData from '../../../../../data/index/coolers.index.json';
import caseData from '../../../../../data/index/cases.index.json';

export async function getStaticPaths() {
  const coolers = coolerData.items;
  const cases = caseData.items;
  const paths = [];

  for (const cooler of coolers) {
    for (const pcCase of cases) {
      paths.push({
        params: { cooler: cooler.id, case: pcCase.id },
        props: { cooler, pcCase }
      });
    }
  }
  return paths;
}

const { cooler, pcCase } = Astro.props;
const result = checkCoolerCase(cooler as any, pcCase as any);

const pageTitle = `Will the ${cooler.name} Fit in the ${pcCase.name}? — PSUCheck`;
const pageDescription = `Check heights and RAM clearances for installing the ${cooler.name} in the ${pcCase.name} PC case.`;
---

<Layout
  title={pageTitle}
  description={pageDescription}
>
  <section class="compat-page" style="padding: 3rem 0 6rem;">
    <div class="container">
      <nav class="calc-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true" style="margin: 0 0.5rem; opacity: 0.5;">›</span>
        <a href="/compatibility/">Compatibility</a>
        <span aria-hidden="true" style="margin: 0 0.5rem; opacity: 0.5;">›</span>
        <span aria-current="page">{cooler.name} to {pcCase.name}</span>
      </nav>

      <header style="margin-bottom: 2.5rem; margin-top: 1.5rem;">
        <span style="font-size: 0.75rem; font-weight: 700; color: var(--color-accent-cyan); text-transform: uppercase; letter-spacing: 0.1em; display: block; margin-bottom: 0.5rem;">CPU Cooler to Case Clearances</span>
        <h1 style="font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 900; margin: 0 0 1rem; line-height: 1.15;">
          Clearance Check: <span class="gradient-text">{cooler.name}</span> in <span class="gradient-text">{pcCase.name}</span>
        </h1>
      </header>

      {/* Verdict Panel */}
      <div class="card" style={`padding: 1.5rem; border-left: 4px solid ${result.verdict === 'PASS' ? 'var(--color-safe)' : result.verdict === 'WARN' ? 'var(--color-warning)' : 'var(--color-danger)'}; margin-bottom: 2.5rem;`}>
        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
          <span class={`badge ${result.verdict === 'PASS' ? 'badge-safe' : result.verdict === 'WARN' ? 'badge-warning' : 'badge-danger'}`} style="font-size: 0.85rem; padding: 4px 10px;">
            {result.verdict === 'PASS' ? 'Compatible Fit' : result.verdict === 'WARN' ? 'Caution' : 'Incompatible'}
          </span>
        </div>
        <p style="font-size: 1rem; line-height: 1.6; color: var(--color-text-primary);">
          {result.verdict === 'PASS' ? (
            <span>Yes! The <strong>{cooler.name}</strong> fits comfortably in the <strong>{pcCase.name}</strong>. The heatsink height is <strong>{cooler.height}mm</strong> and the case allows CPU coolers up to <strong>{pcCase.maxCoolerHeight}mm</strong> tall.</span>
          ) : result.verdict === 'WARN' ? (
            <span>The fit is <strong>tight</strong> or RAM clearance conflicts might require fan offsets.</span>
          ) : (
            <span>No. The <strong>{cooler.name}</strong> height exceeds the case clearance limit of <strong>{pcCase.maxCoolerHeight}mm</strong>.</span>
          )}
        </p>

        {result.warnings.map(w => (
          <div style="margin-top: 0.75rem; color: var(--color-warning-text); font-size: 0.875rem;">⚠️ {w}</div>
        ))}
        {result.failures.map(f => (
          <div style="margin-top: 0.75rem; color: var(--color-danger-text); font-size: 0.875rem;">❌ {f}</div>
        ))}
      </div>

      {/* Details Table */}
      <div class="card" style="padding: 1.5rem; border: 1px solid var(--border-subtle); border-radius: var(--radius-lg); margin-bottom: 3rem;">
        <h2 style="font-size: 1.15rem; font-weight: 800; color: var(--text-primary); margin: 0 0 1.25rem; text-transform: uppercase; letter-spacing: 0.05em;">Clearance Checklist</h2>
        <div style="overflow-x: auto;">
          <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.875rem;">
            <thead>
              <tr style="border-bottom: 2px solid var(--border-subtle); color: var(--text-secondary);">
                <th style="padding: 0.5rem 0.75rem;">Metric</th>
                <th style="padding: 0.5rem 0.75rem;">Cooler Dimension</th>
                <th style="padding: 0.5rem 0.75rem;">Max Case Clearance</th>
                <th style="padding: 0.5rem 0.75rem;">Status</th>
              </tr>
            </thead>
            <tbody>
              <tr style="border-bottom: 1px solid var(--border-subtle);">
                <td style="padding: 0.75rem; font-weight: 700;">Cooler Height</td>
                <td style="padding: 0.75rem;">{cooler.height}mm</td>
                <td style="padding: 0.75rem;">{pcCase.maxCoolerHeight}mm</td>
                <td style="padding: 0.75rem;">{cooler.height <= pcCase.maxCoolerHeight ? '✅ Fits' : '❌ Too Tall'}</td>
              </tr>
              <tr style="border-bottom: 1px solid var(--border-subtle);">
                <td style="padding: 0.75rem; font-weight: 700;">RAM Clearance Space</td>
                <td style="padding: 0.75rem;">{cooler.ramClearanceMaxHeight > 0 ? `${cooler.ramClearanceMaxHeight}mm` : 'Unlimited'}</td>
                <td style="padding: 0.75rem;">—</td>
                <td style="padding: 0.75rem;">—</td>
              </tr>
              <tr style="border-bottom: 1px solid var(--border-subtle);">
                <td style="padding: 0.75rem; font-weight: 700;">TDP Dissipation Limit</td>
                <td style="padding: 0.75rem;">{cooler.tdpRating}W</td>
                <td style="padding: 0.75rem;">—</td>
                <td style="padding: 0.75rem;">—</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>
</Layout>
