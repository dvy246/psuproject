---
// PSUCheck — Base Layout
// Shared across all MPA routes.
// Dark/light theme via data-theme on <html>.
// Every page: meta, OG, schema, skip link, header, footer.

import '../styles/tailwind.css';
import '../styles/global.css';
import '../styles/assembly-desk.css';

const breadcrumbNames: Record<string, string> = {
  '/': 'Home',
  '/psu-calculator': 'PSU Calculator',
  '/pc-builder': 'PC Builder',
  '/psu-checker': 'PSU Checker',
  '/psu': 'PSU Database',
  '/psu-for': 'PSU Finder',
  '/charger-for': 'USB-C Charger Sizer',
  '/compare/desktop-vs-laptop': 'Desktop vs Laptop TCO',
  '/guides': 'Guides',
  '/about': 'About',
  '/methodology': 'Methodology',
  '/compare': 'Compare',
  '/compare/psu': 'PSU Comparison',
  '/compare/ups-calculator': 'UPS Sizer',
  '/compare/breaker-calculator': 'Circuit Breaker Planner',
  '/contact': 'Contact',
  '/privacy-policy': 'Privacy Policy',
  '/terms': 'Terms & Conditions',
  '/disclaimer': 'Disclaimer',
  '/editorial-policy': 'Editorial Policy',
};

const guideNames: Record<string, string> = {
  'psu-sizing-guide': 'PSU Sizing Guide',
  'atx-3-1-guide': 'ATX 3.1 Guide',
  'psu-efficiency-guide': '80+ Efficiency Guide',
  'cybenetics-vs-80-plus': 'Cybenetics vs 80 PLUS',
  'gpu-power-connectors': 'GPU Power Connectors',
  'psu-cable-extensions': 'Cable Extensions Safety',
  'single-vs-multi-rail': 'Single vs Multi Rail',
  'ups-backup-power': 'UPS & Surge Protection',
  'how-to-build-a-pc': 'How to Build a PC',
  'budget-guide': 'PC Budget Guide',
  'building-tips': 'PC Building Tips',
  'pc-bottleneck-guide': 'PC Bottleneck Guide',
  'overclocking-power-draw': 'Overclocking Power',
  'aio-cooler-power-draw': 'AIO Cooler Power',
  'pc-idle-power': 'PC Idle Power',
  'how-to-test-a-psu': 'How to Test a PSU',
  'psu-lifespan': 'PSU Lifespan & Aging',
  'psu-coil-whine': 'PSU Coil Whine',
  'quiet-psu-guide': 'Quiet PSU Guide',
  'fanless-psu-guide': 'Fanless PSU Guide',
  'psu-fan-direction': 'PSU Fan Direction',
  'modular-vs-non-modular-psu': 'Modular vs Non-Modular',
  'sfx-vs-atx-psu': 'SFX vs ATX Guide',
  'sfx-l-psu-guide': 'SFX-L Clearance Guide',
  'server-vs-desktop-psu': 'Server vs Desktop PSU',
  'psu-cable-compatibility': 'Modular Cable Pinout Safety',
  'power-glossary': 'PC Power Glossary',
  'best-psu-for-gaming': 'Best PSU for Gaming 2026',
  '750w-vs-850w-psu': '750W vs 850W PSU',
  'oracle': 'PSU Oracle',
};

function formatSlug(seg: string): string {
  const known = guideNames[seg];
  if (known) return known;
  return seg.replace(/-/g, ' ')
    .replace(/\b\w/g, c => c.toUpperCase())
    .replace(/\bPsu\b/g, 'PSU')
    .replace(/\bAtx\b/g, 'ATX')
    .replace(/\bRtx\b/g, 'RTX')
    .replace(/\bGpu\b/g, 'GPU')
    .replace(/\bCpu\b/g, 'CPU')
    .replace(/\bTco\b/g, 'TCO')
    .replace(/\bSfx\b/g, 'SFX')
    .replace(/\bPsu\b/g, 'PSU');
}

function buildBreadcrumbSchema(pathname: string) {
  const segments = pathname.split('/').filter(Boolean);
  const items = [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://psucheck.com/' }];
  let accumulated = '';
  for (const seg of segments) {
    accumulated += '/' + seg;
    const known = breadcrumbNames[accumulated];
    const name = known || formatSlug(seg);
    if (accumulated !== pathname) {
      items.push({ '@type': 'ListItem', position: items.length + 1, name, item: 'https://psucheck.com' + accumulated + '/' });
    } else {
      items.push({ '@type': 'ListItem', position: items.length + 1, name });
    }
  }
  if (items.length === 1) return null;
  return { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: items };
}

export interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  schema?: object | object[];
  noIndex?: boolean;
}

const {
  title,
  description,
  canonicalUrl = Astro.url.origin + Astro.url.pathname,
  ogImage = '/pc-hero.png',
  schema,
  noIndex = false,
} = Astro.props;

const siteTitle = title.includes('PSUCheck') ? title : `${title} | PSUCheck`;

// Dynamic TechArticle injection for guide subpages
const isGuidePage = Astro.url.pathname.startsWith('/guides/') && Astro.url.pathname !== '/guides' && Astro.url.pathname !== '/guides/';
const techArticleSchema = isGuidePage ? {
  "@type": "TechArticle",
  "headline": title,
  "description": description,
  "image": [Astro.url.origin + ogImage],
  "datePublished": "2026-01-15T08:00:00Z",
  "dateModified": new Date().toISOString(),
  "author": {
    "@type": "Organization",
    "name": "PSUCheck Engineering Team",
    "url": "https://psucheck.com/about"
  },
  "publisher": {
    "@type": "Organization",
    "name": "PSUCheck",
    "logo": {
      "@type": "ImageObject",
      "url": "https://psucheck.com/favicon.svg"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalUrl
  }
} : null;

// Combine schemas under @graph
let finalSchemas = [];
if (schema) {
  if (Array.isArray(schema)) {
    finalSchemas.push(...schema);
  } else {
    finalSchemas.push(schema);
  }
}
if (techArticleSchema) {
  finalSchemas.push(techArticleSchema);
}

const schemaStr = finalSchemas.length > 0
  ? JSON.stringify(finalSchemas.length === 1 ? finalSchemas[0] : { '@context': 'https://schema.org', '@graph': finalSchemas }, null, 0)
  : null;
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
