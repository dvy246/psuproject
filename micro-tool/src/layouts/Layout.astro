        <a href={`https://x.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noopener noreferrer" class="btn btn-secondary btn-sm" style="min-height:32px; padding:4px 12px; font-size:0.8rem; text-decoration:none;" aria-label="Share on X (Twitter)">X / Twitter</a>
        <a href={`https://www.reddit.com/submit?title=${encodeURIComponent(title)}&url=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noopener noreferrer" class="btn btn-secondary btn-sm" style="min-height:32px; padding:4px 12px; font-size:0.8rem; text-decoration:none;" aria-label="Share on Reddit">Reddit</a>
        <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noopener noreferrer" class="btn btn-secondary btn-sm" style="min-height:32px; padding:4px 12px; font-size:0.8rem; text-decoration:none;" aria-label="Share on Facebook">Facebook</a>
      </div>
    </div>
