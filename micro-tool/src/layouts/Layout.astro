---
// VoltForge — Base Layout
// Shared across all MPA routes.
// Dark/light theme via data-theme on <html>.
// Every page: meta, OG, schema, skip link, header, footer.

import '../styles/tailwind.css';
import '../styles/global.css';
import '../styles/assembly-desk.css';

const breadcrumbNames: Record<string, string> = {
  '/': 'Home',
  '/psu-calculator': 'PSU Calculator',
  '/pc-builder': 'PC Builder',
  '/psu-checker': 'PSU Checker',
  '/guides': 'Guides',
  '/about': 'About',
  '/methodology': 'Methodology',
  '/compare': 'Compare',
  '/compare/psu': 'PSU Comparison',
  '/contact': 'Contact',
  '/privacy-policy': 'Privacy Policy',
  '/terms': 'Terms & Conditions',
};

const guideNames: Record<string, string> = {
  'psu-sizing-guide': 'PSU Sizing Guide',
  'atx-3-1-guide': 'ATX 3.1 Guide',
  'psu-efficiency-guide': '80+ Efficiency Guide',
  'cybenetics-vs-80-plus': 'Cybenetics vs 80 PLUS',
  'gpu-power-connectors': 'GPU Power Connectors',
  'psu-cable-extensions': 'Cable Extensions Safety',
  'single-vs-multi-rail': 'Single vs Multi Rail',
  'ups-backup-power': 'UPS & Surge Protection',
  'how-to-build-a-pc': 'How to Build a PC',
  'budget-guide': 'PC Budget Guide',
  'building-tips': 'PC Building Tips',
  'pc-bottleneck-guide': 'PC Bottleneck Guide',
  'overclocking-power-draw': 'Overclocking Power',
  'aio-cooler-power-draw': 'AIO Cooler Power',
  'pc-idle-power': 'PC Idle Power',
  'how-to-test-a-psu': 'How to Test a PSU',
  'psu-lifespan': 'PSU Lifespan & Aging',
  'psu-coil-whine': 'PSU Coil Whine',
  'quiet-psu-guide': 'Quiet PSU Guide',
  'fanless-psu-guide': 'Fanless PSU Guide',
  'psu-fan-direction': 'PSU Fan Direction',
  'modular-vs-non-modular-psu': 'Modular vs Non-Modular',
  'sfx-vs-atx-psu': 'SFX vs ATX Guide',
  'sfx-l-psu-guide': 'SFX-L Clearance Guide',
  'server-vs-desktop-psu': 'Server vs Desktop PSU',
  'oracle': 'PSU Oracle',
};

function formatSlug(seg: string): string {
  const known = guideNames[seg];
  if (known) return known;
  return seg.replace(/-/g, ' ')
    .replace(/\b\w/g, c => c.toUpperCase())
    .replace(/\bPsu\b/g, 'PSU')
    .replace(/\bAtx\b/g, 'ATX')
    .replace(/\bRtx\b/g, 'RTX')
    .replace(/\bGpu\b/g, 'GPU')
    .replace(/\bCpu\b/g, 'CPU')
    .replace(/\bTco\b/g, 'TCO')
    .replace(/\bSfx\b/g, 'SFX')
    .replace(/\bPsu\b/g, 'PSU');
}

function buildBreadcrumbSchema(pathname: string) {
  const segments = pathname.split('/').filter(Boolean);
  const items = [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://voltforge.app/' }];
  let accumulated = '';
  for (const seg of segments) {
    accumulated += '/' + seg;
    const known = breadcrumbNames[accumulated];
    const name = known || formatSlug(seg);
    if (accumulated !== pathname) {
      items.push({ '@type': 'ListItem', position: items.length + 1, name, item: 'https://voltforge.app' + accumulated });
    } else {
      items.push({ '@type': 'ListItem', position: items.length + 1, name });
    }
  }
  if (items.length === 1) return null;
  return { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: items };
}

export interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  schema?: object | object[];
  noIndex?: boolean;
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  ogImage = '/pc-hero.png',
  schema,
  noIndex = false,
} = Astro.props;

const siteTitle = title.includes('VoltForge') ? title : `${title} | VoltForge`;
const schemaStr = schema ? JSON.stringify(Array.isArray(schema) ? { '@context': 'https://schema.org', '@graph': schema } : schema, null, 0) : null;
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <title>{siteTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  {noIndex && <meta name="robots" content="noindex, nofollow" />}
  <meta property="og:type" content="website" />
  <meta property="og:title" content={siteTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
  <meta property="og:site_name" content="VoltForge" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={siteTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <!-- Design system fonts: Fira Code (monospace/display) + Fira Sans (body) -->
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600;700&family=Fira+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <meta name="apple-mobile-web-app-title" content="VoltForge" />
  <link rel="manifest" href="/site.webmanifest" />
  <script is:inline>
    (function() {
      const stored = localStorage.getItem('vf-theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const theme = stored || (prefersDark ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
  {schemaStr && <script type="application/ld+json" set:html={schemaStr} />}
  {buildBreadcrumbSchema(Astro.url.pathname) && <script type="application/ld+json" set:html={JSON.stringify(buildBreadcrumbSchema(Astro.url.pathname))} />}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context":"https://schema.org","@type":"Organization",
    "name":"VoltForge","url":"https://voltforge.app",
    "description":"Independent PC power supply calculator and build cost estimator.",
    "logo":{"@type":"ImageObject","url":"https://voltforge.app/favicon.svg"},
    "contactPoint":{"@type":"ContactPoint","contactType":"customer support","url":"https://voltforge.app/contact"}
  })} />
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <header class="site-header" role="banner">
    <div class="container">
      <nav class="nav-inner" role="navigation" aria-label="Main navigation">
        <a href="/" class="nav-logo" aria-label="VoltForge home">⚡ VoltForge</a>
        <ul class="nav-links" id="nav-links">
          <li><a href="/psu-calculator">PSU Calculator</a></li>
          <li><a href="/pc-builder">PC Builder</a></li>
          <li><a href="/psu-checker">PSU Checker</a></li>
          <li><a href="/guides">Guides</a></li>
          <li><a href="/about">About</a></li>
        </ul>
        <div class="nav-right">
          <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark and light mode" type="button">
            <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
            <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </button>
          <button class="nav-mobile-toggle" id="nav-mobile-toggle" aria-label="Open navigation menu" aria-expanded="false" aria-controls="nav-links" type="button">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          </button>
        </div>
      </nav>
    </div>
  </header>

  <main id="main-content" tabindex="-1">
    <slot />
  </main>

  <footer class="site-footer" role="contentinfo">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-section">
          <a href="/" class="nav-logo" style="display:inline-block;margin-bottom:0.75rem;">⚡ VoltForge</a>
          <p style="font-size:0.875rem;max-width:28ch;">Independent, unbiased PC power supply calculator and build cost estimator.</p>
          <p style="font-size:0.75rem;margin-top:0.75rem;color:var(--text-tertiary);">Methodology sources: Cybenetics, TechPowerUp, Intel ARK, AMD official specs, 80 PLUS certification data.</p>
        </div>
        <div class="footer-section">
          <h4>Calculators</h4>
          <ul>
            <li><a href="/psu-calculator">PSU Calculator</a></li>
            <li><a href="/pc-builder">PC Builder & Cost</a></li>
            <li><a href="/psu-checker">PSU Upgrade Checker</a></li>
            <li><a href="/compare/psu">PSU Comparison</a></li>
            <li><a href="/methodology">Our Methodology</a></li>
          </ul>
        </div>
        <div class="footer-section">
          <h4><a href="/guides" style="color:inherit;text-decoration:none;">Guides</a></h4>
          <ul>
            <li><a href="/guides/how-to-build-a-pc">How to Build a PC</a></li>
            <li><a href="/guides/atx-3-1-guide">ATX 3.1 Guide</a></li>
            <li><a href="/guides/psu-sizing-guide">PSU Sizing Guide</a></li>
            <li><a href="/guides/psu-efficiency-guide">80+ Efficiency Guide</a></li>
            <li><a href="/guides/budget-guide">PC Budget Guide</a></li>
            <li><a href="/guides/building-tips">Building Tips</a></li>
          </ul>
        </div>
        <div class="footer-section">
          <h4>Company</h4>
          <ul>
            <li><a href="/about">About Us</a></li>
            <li><a href="/contact">Contact</a></li>
            <li><a href="/privacy-policy">Privacy Policy</a></li>
            <li><a href="/terms">Terms &amp; Conditions</a></li>
            <li><a href="/methodology">Methodology</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <div>
          <p>&copy; {new Date().getFullYear()} VoltForge. All rights reserved.</p>
          <p style="margin-top:0.25rem;">VoltForge participates in the Amazon Associates and Newegg affiliate programs. We may earn a commission when you click affiliate links at no extra cost to you.</p>
        </div>
        <div style="display:flex;gap:1rem;align-items:center;flex-wrap:wrap;">
          <a href="/privacy-policy" style="color:var(--text-tertiary);font-size:0.75rem;">Privacy</a>
          <a href="/terms" style="color:var(--text-tertiary);font-size:0.75rem;">Terms</a>
          <a href="/contact" style="color:var(--text-tertiary);font-size:0.75rem;">Contact</a>
        </div>
      </div>
    </div>
  </footer>

  <script is:inline>
    const toggle = document.getElementById('theme-toggle');
    const html = document.documentElement;
    const sunIcon = document.getElementById('icon-sun');
    const moonIcon = document.getElementById('icon-moon');
    function applyTheme(theme) {
      html.setAttribute('data-theme', theme);
      localStorage.setItem('vf-theme', theme);
      if (theme === 'dark') {
        sunIcon.style.display = '';
        moonIcon.style.display = 'none';
        toggle.setAttribute('aria-label', 'Switch to light mode');
      } else {
        sunIcon.style.display = 'none';
        moonIcon.style.display = '';
        toggle.setAttribute('aria-label', 'Switch to dark mode');
      }
    }
    applyTheme(html.getAttribute('data-theme') || 'dark');
    toggle.addEventListener('click', () => {
      applyTheme(html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark');
    });
    const mobileToggle = document.getElementById('nav-mobile-toggle');
    const navLinks = document.getElementById('nav-links');
    mobileToggle.addEventListener('click', () => {
      const isOpen = navLinks.classList.toggle('open');
      mobileToggle.setAttribute('aria-expanded', String(isOpen));
      mobileToggle.setAttribute('aria-label', isOpen ? 'Close navigation menu' : 'Open navigation menu');
    });
    document.addEventListener('click', (e) => {
      if (!mobileToggle.contains(e.target) && !navLinks.contains(e.target)) {
        navLinks.classList.remove('open');
        mobileToggle.setAttribute('aria-expanded', 'false');
      }
    });
  </script>
</body>
</html>
