  <!-- Client-side script to handle localStorage feedback storing -->
  <script is:inline>
    (function() {
      const pathname = window.location.pathname;
      const yesBtn = document.getElementById('feedback-btn-yes');
      const noBtn = document.getElementById('feedback-btn-no');
      const thanksText = document.getElementById('feedback-thanks');
      
      const stored = localStorage.getItem('helpful_' + pathname);
      if (stored) {
        if (yesBtn && noBtn) {
          yesBtn.style.display = 'none';
          noBtn.style.display = 'none';
        }
        if (thanksText) thanksText.style.display = 'inline';
      }

      function handleFeedback(status) {
        localStorage.setItem('helpful_' + pathname, status);
        if (yesBtn && noBtn) {
          yesBtn.style.display = 'none';
          noBtn.style.display = 'none';
        }
        if (thanksText) {
          thanksText.style.display = 'inline';
        }
      }

      if (yesBtn) yesBtn.addEventListener('click', () => handleFeedback('yes'));
      if (noBtn) noBtn.addEventListener('click', () => handleFeedback('no'));
    })();
  </script>

